---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import PrismBg from "../components/PrismBg.astro";

const plans = [
  {
    name: "Max",
    priceMonthly: "$250",
    priceAnnual: "$208",
    annualBilledNote: "$2,500 billed yearly — save $500",
    monthlyBilledNote: "Billed monthly · cancel anytime",
    blurb: "Unlimited leads, full SEO, and review collection to scale.",
    featured: true,
    cta: "Book Call",
    features: [
      { label: "Max leads per month", value: "Unlimited" },
      { label: "SEO pages", value: "Unlimited" },
      { label: "Hosting & support", value: true },
      { label: "Custom domain", value: true },
      { label: "SMS lead notifications", value: true },
      { label: "Website editor", value: true },
      { label: "About Us page", value: true },
      { label: "Embedded reviews", value: true },
      { label: "Review collection", value: true },
    ],
  },
];

// Trust bar — real client quotes (condensed)
const trustQuotes = [
  { quote: "After a few days I already saw 4–7 leads a day texted to my phone.", name: "Glenn R." },
  { quote: "We booked several hundred thousand dollars of work in the first few months.", name: "Chris K." },
  { quote: "I've seen a 60% increase in revenue since having this website up!", name: "Ethan D." },
  { quote: "The website works PERFECT — a real rise in traffic, bookings and sales.", name: "Maria R." },
  { quote: "It's bringing in a ton of new leads. So much better than last month already!", name: "Chelsea C." },
  { quote: "Revenue is up, it was quick and easy, and it kept my costs down.", name: "Donovin F." },
  { quote: "Within a month my calendar was booked solid through the spring.", name: "Marcus W." },
  { quote: "I wake up to new quote requests every single morning.", name: "Tanya B." },
];

const faqs = [
  {
    q: "Is there really a free trial?",
    a: "Yes — every plan includes a 7-day free trial. Get your site live and see the leads come in before you pay a cent.",
  },
  {
    q: "Are there any contracts?",
    a: "No contracts, ever. It's month-to-month and you can cancel anytime.",
  },
  {
    q: "How fast can I go live?",
    a: "Onboarding takes about 5 minutes. Most contractors are online within a week of signing up.",
  },
  {
    q: "What happens when I get a lead?",
    a: "We text it straight to your phone the moment someone requests a quote, signs a contract, completes a payment, or books a meeting. No dashboard required.",
  },
  {
    q: "Why is it so affordable?",
    a: "We charge less than your current website costs you in missed leads. Do the math — one extra job usually covers it for months.",
  },
];
---

<Layout
  title="Pricing — Stacked"
  description="Simple pricing for contractor websites. One plan at $250/mo. 7-day free trial, no contracts, cancel anytime."
>
  <section class="page-hero">
    <PrismBg />
    <div class="container center-narrow text-center">
      <span class="eyebrow">Pricing</span>
      <h1>One price. Zero excuses.</h1>
      <p class="lead" style="margin: 0 auto;">
        We charge less than your current website costs you in missed leads.
        Do the math, then start your 7-day free trial.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="billing-toggle" data-billing-toggle>
        <button class="billing-opt is-active" data-billing="monthly">
          Monthly
        </button>
        <button class="billing-opt" data-billing="annual">
          Annually
          <span class="billing-save">2 months free</span>
        </button>
      </div>

      <div class="pricing-grid">
        {
          plans.map((p) => (
            <article class:list={["plan", { featured: p.featured }]}>
              {p.featured && <span class="badge">Most Popular</span>}
              <h3 class="plan-name">{p.name}</h3>
              <p class="plan-blurb">{p.blurb}</p>
              <div class="plan-price">
                <span
                  class="amount"
                  data-monthly={p.priceMonthly}
                  data-annual={p.priceAnnual}
                >
                  {p.priceMonthly}
                </span>
                <span class="cadence">/mo</span>
              </div>
              <span
                class="plan-billed"
                data-monthly={p.monthlyBilledNote}
                data-annual={p.annualBilledNote}
              >
                {p.monthlyBilledNote}
              </span>
              <span class="trial">7-day free trial included</span>
              <a
                href="/contact"
                class:list={[
                  "btn",
                  "plan-cta",
                  p.featured ? "btn-primary" : "btn-outline",
                ]}
              >
                {p.cta}
              </a>
              <ul class="plan-features">
                {p.features.map((f) => (
                  <li class:list={{ off: f.value === false }}>
                    <span class="feat-label">{f.label}</span>
                    <span class="feat-value">
                      {f.value === true ? (
                        <span class="yes">✓</span>
                      ) : f.value === false ? (
                        <span class="no">—</span>
                      ) : (
                        f.value
                      )}
                    </span>
                  </li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
      <p class="text-center" style="margin-top: 28px; color: var(--muted);">
        No contracts. Cancel anytime.
      </p>
    </div>
  </section>

  <section class="section surface-soft">
    <div class="container center-narrow">
      <div class="text-center">
        <span class="eyebrow">Questions</span>
        <h2>Pricing FAQ</h2>
      </div>
      <div class="faq" style="margin-top: 32px;">
        {
          faqs.map((f) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section trust-section">
    <div class="container text-center">
      <span class="eyebrow">Don't take our word for it</span>
      <h2>The proof is in the pudding</h2>
    </div>
    <div class="trust-marquee">
      <div class="trust-track">
        {
          [...trustQuotes, ...trustQuotes].map((t) => (
            <figure class="trust-chip">
              <span class="trust-stars">★★★★★</span>
              <p>"{t.quote}"</p>
              <figcaption>— {t.name}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Ready to build your stack?"
    text="Get your site live, see the leads come in, then decide. No contracts, cancel anytime."
  />
</Layout>

<style>
  .page-hero {
    background: var(--surface-soft);
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .page-hero {
    background: var(--bg);
  }

  .page-hero > .container {
    position: relative;
    z-index: 1;
  }

  /* Billing toggle */
  .billing-toggle {
    display: inline-flex;
    gap: 4px;
    padding: 5px;
    margin: 0 auto 36px;
    border-radius: 999px;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    position: relative;
    left: 50%;
    transform: translateX(-50%);
  }

  .billing-opt {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 0;
    cursor: pointer;
    padding: 10px 20px;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    font-size: 0.92rem;
    color: var(--ink-soft);
    background: transparent;
    transition: background 0.18s ease, color 0.18s ease;
  }

  .billing-opt.is-active {
    background: var(--brand);
    color: #fff;
    box-shadow: var(--shadow-sm);
  }

  .billing-save {
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--accent) 22%, transparent);
    color: var(--accent);
  }

  .billing-opt.is-active .billing-save {
    background: rgba(255, 255, 255, 0.22);
    color: #fff;
  }

  .plan-billed {
    display: block;
    color: var(--muted);
    font-size: 0.82rem;
    margin-bottom: 14px;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: minmax(0, 540px);
    gap: 28px;
    justify-content: center;
    align-items: start;
  }

  .plan {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 34px 30px;
    box-shadow: var(--shadow-sm);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .plan:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .plan.featured {
    border-color: var(--brand);
    box-shadow: var(--shadow-lg);
  }

  .badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brand);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
  }

  .plan-name {
    font-size: 1.3rem;
  }

  .plan-blurb {
    min-height: 48px;
    margin-bottom: 12px;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 6px;
  }

  .amount {
    font-size: 2.8rem;
    font-weight: 900;
    letter-spacing: -0.03em;
  }

  .cadence {
    color: var(--muted);
    font-weight: 600;
  }

  .trial {
    display: block;
    color: var(--brand);
    font-weight: 700;
    font-size: 0.85rem;
    margin-bottom: 20px;
  }

  .plan-cta {
    width: 100%;
    margin-bottom: 24px;
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0;
  }

  .plan-features li {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    font-size: 0.95rem;
  }

  .plan-features li:last-child {
    border-bottom: 0;
  }

  .plan-features li.off .feat-label {
    color: var(--muted);
  }

  .feat-label {
    color: var(--ink);
  }

  .feat-value {
    font-weight: 700;
    color: var(--ink);
    white-space: nowrap;
  }

  .yes {
    color: var(--brand);
  }

  .no {
    color: var(--muted);
  }

  .faq {
    display: grid;
    gap: 12px;
  }

  .faq-item {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 4px 20px;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 700;
    padding: 16px 0;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.4rem;
    color: var(--brand);
    font-weight: 400;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item p {
    padding-bottom: 16px;
    margin: 0;
  }

  /* Trust bar marquee */
  .trust-section {
    overflow: hidden;
  }

  .trust-marquee {
    margin-top: 40px;
    position: relative;
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(
      90deg,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
  }

  .trust-track {
    display: flex;
    gap: 18px;
    width: max-content;
    animation: trustScroll 50s linear infinite;
  }

  .trust-marquee:hover .trust-track {
    animation-play-state: paused;
  }

  @keyframes trustScroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .trust-chip {
    flex-shrink: 0;
    width: 320px;
    margin: 0;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px 24px;
    box-shadow: var(--shadow-sm);
  }

  .trust-stars {
    color: #f5a623;
    font-size: 0.9rem;
    letter-spacing: 1px;
  }

  .trust-chip p {
    margin: 10px 0 12px;
    color: var(--ink);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .trust-chip figcaption {
    font-weight: 700;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .trust-track {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
      justify-content: center;
    }
    .trust-marquee {
      -webkit-mask-image: none;
      mask-image: none;
    }
  }

  @media (max-width: 760px) {
    .pricing-grid {
      grid-template-columns: 1fr;
    }
    .billing-opt {
      padding: 9px 16px;
      font-size: 0.85rem;
    }
  }
</style>

<script>
  const toggle = document.querySelector<HTMLElement>("[data-billing-toggle]");
  if (toggle) {
    const opts = Array.from(
      toggle.querySelectorAll<HTMLButtonElement>(".billing-opt")
    );
    const swap = (mode: string) => {
      document
        .querySelectorAll<HTMLElement>("[data-monthly][data-annual]")
        .forEach((el) => {
          const val = el.getAttribute(`data-${mode}`);
          if (val) el.textContent = val;
        });
      opts.forEach((o) =>
        o.classList.toggle("is-active", o.getAttribute("data-billing") === mode)
      );
    };
    opts.forEach((o) =>
      o.addEventListener("click", () =>
        swap(o.getAttribute("data-billing") || "monthly")
      )
    );
  }
</script>
