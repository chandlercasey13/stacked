---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";

const trustChips = [
  "Roofing",
  "Plumbing",
  "HVAC",
  "Landscaping",
  "Electrical",
  "Remodeling",
  "Marine Construction",
];

// Benefit cards — sticky stacking on scroll
const painPoints = [
  {
    eyebrow: "Seamless across devices",
    title: "Get leads anywhere, stay in sync",
    text: "Your site works beautifully on every screen, and every lead lands on your phone the instant it comes in.",
    points: ["Works on every screen", "Leads land on your phone instantly"],
    visual: "devices",
  },
  {
    eyebrow: "Get found on Google",
    title: "Rank high and get found",
    text: "A great-looking site is useless if nobody finds it. Stacked sites are built to rank, so customers searching for your services find you first.",
    points: ["Built to rank on Google", "Found by local customers first"],
    visual: "search",
  },
  {
    eyebrow: "Never miss a lead",
    title: "Leads straight to your phone",
    text: "Who checks email anymore — especially the spam folder where lead alerts end up? We text you the moment a customer takes action so you respond in minutes, not hours.",
    points: ["Texted the moment a lead acts", "Respond in minutes, not hours"],
    visual: "sms",
  },
];

// Features / how it works (quote → book → pay)
const howItWorks = [
  {
    step: "01",
    title: "Get the quote request",
    text: "Visitors request a quote from your site and it's texted straight to your phone — no missed leads.",
    stat: "Instant",
    statLabel: "Lead to your phone",
  },
  {
    step: "02",
    title: "Book the job",
    text: "Lock in the meeting with built-in scheduling and automated reminders so nobody no-shows.",
    stat: "Auto",
    statLabel: "Reminders sent",
  },
  {
    step: "03",
    title: "Get paid",
    text: "Send the invoice, collect payment, and get a text the moment the money hits.",
    stat: "Same day",
    statLabel: "Payouts",
  },
];

// Product showcase / demo callouts
const showcaseCallouts = [
  {
    title: "Lead lands on your phone",
    text: "Every quote request, signed contract, and payment is texted to you instantly.",
  },
  {
    title: "Reviews build trust",
    text: "Collect and showcase 5-star reviews right where buyers are deciding.",
  },
  {
    title: "Loads in a blink",
    text: "A fast, modern build keeps visitors from bouncing on mobile or desktop.",
  },
];

// Features (full detailed breakdown)
const features = [
  {
    icon: "📱",
    title: "SMS Lead Notifications",
    text: "Who checks email anymore — especially the spam folder where lead alerts end up? We text you the second something happens.",
    points: [
      "Instant text when a quote is requested",
      "Alerts when a contract is signed",
      "Pings when a payment completes",
      "Notifications when a meeting is booked",
    ],
  },
  {
    icon: "⚡",
    title: "Load Fast",
    text: "Slow sites lose leads. Stacked sites are built on a modern, lightning-fast stack so visitors never bounce.",
    points: [
      "Optimized, modern build",
      "Fast on mobile and desktop",
      "Hosting & support included",
      "SSL secured out of the box",
    ],
  },
  {
    icon: "🔍",
    title: "Rank High (SEO)",
    text: "A pretty site is useless if no one finds it. We build SEO pages and get you in front of Google.",
    points: [
      "Dedicated SEO pages",
      "Clean, search-friendly structure",
      "Submitted to Google Search Console",
      "Custom domain configured for you",
    ],
  },
  {
    icon: "✍️",
    title: "Website Editor",
    text: "Need to tweak your hours, services, or photos? Edit your own site anytime — or let us handle it.",
    points: [
      "Simple, no-code editor",
      "Update content in minutes",
      "About Us page included",
      "Or hand it off to our team",
    ],
  },
  {
    icon: "⭐",
    title: "Reviews & Social Proof",
    text: "Trust closes deals. Collect new reviews and showcase your best ones right on your site.",
    points: [
      "Review collection built in",
      "Embed your best reviews",
      "Build instant credibility",
      "Turn happy clients into proof",
    ],
  },
  {
    icon: "🌐",
    title: "Done For You",
    text: "You share your business info — we handle the rest. Most contractors are online within a week.",
    points: [
      "Custom domain & DNS setup",
      "Hosting & SSL handled",
      "~5 minute onboarding",
      "Live in days, not months",
    ],
  },
];

// Pricing (condensed)
const plans = [
  {
    name: "Launch",
    price: "$99",
    blurb: "Everything you need to get online and start catching leads.",
    featured: false,
    features: [
      "Up to 30 leads / mo",
      "Hosting & support",
      "Custom domain",
      "SMS lead notifications",
      "Website editor",
    ],
  },
  {
    name: "Max",
    price: "$250",
    blurb: "Unlimited leads, full SEO, and review collection to scale.",
    featured: true,
    features: [
      "Unlimited leads",
      "Unlimited SEO pages",
      "Everything in Launch",
      "Review collection",
      "Priority support",
    ],
  },
];

// Big testimonial + grid
const bigQuote = {
  quote:
    "We've booked several hundred thousand dollars of work in the first few months after rolling out our new websites built by STACKED.",
  name: "Chris Kick",
  role: "Jordan Marine Construction",
};

const reviews = [
  {
    name: "Glenn Robertson",
    quote:
      "It took me 15 minutes to set up my site and after a few days I already saw 4–7 leads coming in daily texted to my phone. I think I'm gonna double my revenue this month!",
  },
  {
    name: "Maria Ramirez",
    quote:
      "The website works PERFECT. Was cheaper than I thought, and I definitely saw a rise in traffic, bookings and sales.",
  },
  {
    name: "Ethan Del Angel",
    quote:
      "Amazing customer service and speed of service! I've seen a 60% increase in revenue since having this website up.",
  },
  {
    name: "Chelsea Casarez",
    quote:
      "I love my Stacked site, it's bringing in a ton of new leads — we're doing so much better than last month already!",
  },
];

// Blog / ideas
const posts = [
  {
    tag: "Featured",
    title: "How contractors win more local leads in 2026",
    kind: "Must Read",
  },
  { tag: "Speed", title: "Why a slow website is costing you jobs", kind: "Tips" },
  {
    tag: "Reviews",
    title: "Turning happy customers into 5-star reviews",
    kind: "Growth",
  },
  {
    tag: "Follow-up",
    title: "Answer the phone or text back? What converts more",
    kind: "Sales",
  },
];
---

<Layout>
  <!-- 1. Hero -->
  <section class="hero">
    <canvas id="liquid-bg" aria-hidden="true"></canvas>
    <div class="container hero-inner text-center">
      <p class="hero-tagline anim-in" style="--delay: 0ms;">
        Built for contractors who want a stacked business.
      </p>
      <h1 class="anim-in" style="--delay: 60ms;">
        Load Fast. <span class="hl">Rank High.</span> Get Paid.
      </h1>
      <p class="lead hero-lead anim-in" style="--delay: 200ms;">
        Stacked builds done-for-you websites that load fast, rank on Google, and
        send every new lead straight to your phone by text. Live in days, not
        months.
      </p>
      <div class="hero-actions anim-in" style="--delay: 340ms;">
        <a href="/contact" class="btn btn-primary">Book Call</a>
        <a href="#features" class="btn btn-outline">See features</a>
      </div>

      <div class="hero-trust anim-in" style="--delay: 460ms;">
        <div class="hero-trust-rating">
          <span class="hero-trust-stars">★★★★★</span>
          <span class="hero-trust-score">4.4</span>
          <span class="hero-trust-label">Excellent on Trustpilot</span>
        </div>
        <span class="hero-trust-divider"></span>
        <div class="hero-trust-avatars">
          <span class="avatar-stack">
            <span class="avatar">GR</span>
            <span class="avatar">MR</span>
            <span class="avatar">CK</span>
            <span class="avatar">EA</span>
          </span>
          <span class="hero-trust-label">Trusted by 500+ contractors</span>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="hero-visual anim-pop" style="--delay: 480ms;" aria-hidden="true">
        <div class="hero-tilt">
          <video
            class="hero-shot"
            src="/FullSizeRender_optimized.mp4"
            poster="/FullSizeRender_first_frame.png"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            disablepictureinpicture
            aria-hidden="true"
          ></video>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Trusted by -->
  <section class="trusted">
    <div class="container text-center">
      <p class="trusted-label" data-reveal>
        Rated 4.4 Excellent on Trustpilot · trusted by contractors in every
        trade
      </p>
      <div class="trusted-row" data-reveal-stagger>
        {trustChips.map((c) => <span class="trusted-chip">{c}</span>)}
      </div>
    </div>
  </section>

  <!-- NEW: Product showcase / demo -->
  <section class="section showcase-section">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <span class="eyebrow">See it in action</span>
        <h2>The actual product, not a promise</h2>
        <p class="lead" style="margin: 0 auto;">
          Here's a real contractor site built on Stacked — fast, modern, and
          wired to send every lead straight to the owner's phone.
        </p>
      </div>

      <div class="showcase-layout" data-reveal>
        <div class="showcase-phone-wrap">
          <div class="device device-iphone-14-pro device-black showcase-iphone">
            <div class="device-frame">
              <img
                class="device-screen"
                src="/contractor-phone.png"
                alt="Contractor site on mobile"
                loading="lazy"
              />
            </div>
            <div class="device-stripe"></div>
            <div class="device-header"></div>
            <div class="device-sensors"></div>
            <div class="device-btns"></div>
            <div class="device-power"></div>
          </div>
          <div class="iphone-glow" aria-hidden="true"></div>
        </div>

        <ul class="showcase-callouts">
          {
            showcaseCallouts.map((c) => (
              <li class="showcase-callout">
                <div>
                  <strong>{c.title}</strong>
                  <p>{c.text}</p>
                </div>
              </li>
            ))
          }
          <li>
            <a href="/contact" class="btn btn-primary">Book Call</a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- NEW: Benefits — sticky stacking cards -->
  <section class="section benefit-section">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <span class="eyebrow">Why Stacked</span>
        <h2>Experience the <span class="hl">future of your trade</span></h2>
      </div>

      <div class="benefit-stack">
        {
          painPoints.map((p, i) => (
            <article
              class:list={["benefit-card", i % 2 === 1 ? "reverse" : ""]}
              style={`--i: ${i}`}
            >
              <div class="benefit-visual" aria-hidden="true">
                {p.visual === "devices" && (
                  <div class="mk mk-devices">
                    <div class="mk-browser">
                      <div class="mk-bar">
                        <span /> <span /> <span />
                      </div>
                      <div class="mk-screen">
                        <span class="mk-pill">★★★★★ 4.4</span>
                        <span class="mk-h" />
                        <span class="mk-line" />
                        <span class="mk-line mk-sm" />
                        <span class="mk-btn">Get a Quote</span>
                      </div>
                    </div>
                    <div class="mk-phone">
                      <span class="mk-phone-label">STACKED</span>
                      <span class="mk-phone-msg">New lead just came in</span>
                    </div>
                  </div>
                )}
                {p.visual === "search" && (
                  <div class="mk mk-search">
                    <div class="mk-searchbar">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <circle cx="11" cy="11" r="7" /><path d="m21 21-4.3-4.3" />
                      </svg>
                      <span class="mk-query">roofing near me</span>
                    </div>
                    <div class="mk-result mk-result-top">
                      <span class="mk-rank">1</span>
                      <div class="mk-result-body">
                        <span class="mk-result-title" />
                        <span class="mk-result-url" />
                      </div>
                    </div>
                    <div class="mk-result">
                      <div class="mk-result-body">
                        <span class="mk-result-title" />
                        <span class="mk-result-url" />
                      </div>
                    </div>
                    <div class="mk-result">
                      <div class="mk-result-body">
                        <span class="mk-result-title" />
                        <span class="mk-result-url" />
                      </div>
                    </div>
                  </div>
                )}
                {p.visual === "sms" && (
                  <div class="mk mk-sms-phone">
                    <span class="mk-sms">
                      <span class="mk-sms-label">STACKED</span>
                      New quote request from Maria R. — Kitchen remodel
                    </span>
                    <span class="mk-sms">
                      <span class="mk-sms-label">STACKED</span>
                      Payment completed — $2,400 deposit
                    </span>
                    <span class="mk-sms">
                      <span class="mk-sms-label">STACKED</span>
                      New meeting booked for Thu 9:00 AM
                    </span>
                  </div>
                )}
              </div>

              <div class="benefit-copy">
                <span class="benefit-eyebrow">{p.eyebrow}</span>
                <h3>{p.title}</h3>
                <p>{p.text}</p>
                <ul class="benefit-checks">
                  {p.points.map((pt) => (
                    <li>
                      <span class="benefit-check-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20 6 9 17l-5-5" />
                        </svg>
                      </span>
                      {pt}
                    </li>
                  ))}
                </ul>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- NEW: How it works — alternating timeline -->
  <section class="section surface-soft">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <span class="eyebrow">How it works</span>
        <h2>Quote → Book → Get paid</h2>
        <p class="lead" style="margin: 0 auto;">
          One simple flow that turns a website visitor into money in your
          account — without you chasing anyone.
        </p>
      </div>

      <ol class="steps-timeline">
        {
          howItWorks.map((s, i) => (
            <li
              class:list={["steps-row", i % 2 === 0 ? "left" : "right"]}
              data-reveal
            >
              <article class="steps-card">
                <span class="steps-eyebrow">Step {i + 1}</span>
                <h3>{s.title}</h3>
                <p>{s.text}</p>
                <div class="steps-stat">
                  <span class="steps-stat-value">{s.stat}</span>
                  <span class="steps-stat-label">{s.statLabel}</span>
                </div>
              </article>
              <span class="steps-marker">{s.step}</span>
            </li>
          ))
        }
      </ol>
    </div>
  </section>

  <!-- Devices showcase -->
  <section class="section devices-section">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <span class="eyebrow">Seamless across devices</span>
        <h2>Manage everything, from anywhere</h2>
      </div>

      <div class="devices-frame" data-reveal>
        <div class="devices-panels">
          <div class="devices-panel active" data-panel="phone">
            <img
              src="/contractor-phone.png"
              alt="Contractor phone with Stacked app"
              class="devices-photo"
            />
          </div>
          <div class="devices-panel" data-panel="web">
            <img
              src="/contractor-web.png"
              alt="Contractor web dashboard"
              class="devices-photo"
            />
          </div>
        </div>

        <div class="devices-toggle" id="devicesToggle">
          <button class="devices-btn active" data-target="phone">Mobile App</button>
          <button class="devices-btn" data-target="web">Web App</button>
        </div>
      </div>
    </div>
  </section>

  <!-- 7. Testimonials -->
  <section class="section surface-soft">
    <div class="container">
      <blockquote class="big-quote" data-reveal>
        <span class="stars">★★★★★</span>
        <p>"{bigQuote.quote}"</p>
        <footer>
          <span class="bq-name">{bigQuote.name}</span>
          <span class="bq-role">{bigQuote.role}</span>
        </footer>
      </blockquote>

      <div class="grid grid-2 review-grid" data-reveal-stagger>
        {
          reviews.map((r) => (
            <blockquote class="card quote">
              <span class="stars">★★★★★</span>
              <p>"{r.quote}"</p>
              <footer>— {r.name}</footer>
            </blockquote>
          ))
        }
      </div>
      <div class="text-center" style="margin-top: 36px;">
        <a href="/testimonials" class="btn btn-outline">Read all reviews →</a>
      </div>
    </div>
  </section>

  <!-- 8. Pricing -->
  <section class="section pricing-section">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <span class="eyebrow">Pricing</span>
        <h2>Simple plans for serious work</h2>
        <p class="lead" style="margin: 0 auto;">
          One price, zero excuses. 7-day free trial, no contracts, cancel
          anytime.
        </p>
      </div>

      <div class="home-pricing" data-reveal-stagger>
        {
          plans.map((p) => (
            <article class:list={["plan", { featured: p.featured }]}>
              {p.featured && <span class="badge">Most Popular</span>}
              <h3 class="plan-name">{p.name}</h3>
              <p class="plan-blurb">{p.blurb}</p>
              <div class="plan-price">
                <span class="amount">{p.price}</span>
                <span class="cadence">/mo</span>
              </div>
              <a
                href="/contact"
                class:list={[
                  "btn",
                  "plan-cta",
                  p.featured ? "btn-primary" : "btn-outline",
                ]}
              >
                Book Call
              </a>
              <ul class="plan-features">
                {p.features.map((f) => (
                  <li>{f}</li>
                ))}
              </ul>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <!-- 9. Blog / Ideas -->
  <section class="section surface-soft">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <span class="eyebrow">Blog</span>
        <h2>Ideas to get more jobs</h2>
      </div>
      <div class="blog-grid" data-reveal-stagger>
        {
          posts.map((p, i) => (
            <article class:list={["blog-card", { feature: i === 0 }]}>
              <div class="blog-thumb">
                <span class="blog-tag">{p.tag}</span>
              </div>
              <div class="blog-body">
                <span class="blog-kind">{p.kind}</span>
                <h3>{p.title}</h3>
              </div>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Ready to get your site live?"
    text="Most contractors are online within a week of signing up. Book a call and we'll have you live within a week."
  />
</Layout>

<style>

  /* NEW: Benefits — sticky stacking cards */
  .benefit-stack {
    margin-top: 56px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .benefit-card {
    position: sticky;
    top: calc(100px + var(--i) * 26px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    padding: 40px;
    border-radius: 16px;
    background: var(--surface);
    border: 1px solid var(--line);
    box-shadow: var(--shadow-lg);
  }

  .benefit-card.reverse .benefit-visual {
    order: 2;
  }

  /* gradient visual panel */
  .benefit-visual {
    position: relative;
    border-radius: 10px;
    padding: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 320px;
    background: color-mix(in srgb, var(--surface) 60%, transparent);
    border: 1px solid color-mix(in srgb, var(--surface) 40%, transparent);
    backdrop-filter: blur(16px);
  }

  .benefit-copy {
    padding: 8px 24px;
  }

  .benefit-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.8rem;
    font-weight: 700;
    color: var(--brand);
  }

  .benefit-eyebrow::before {
    content: "";
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--brand);
  }

  .benefit-copy h3 {
    font-size: clamp(1.5rem, 2.6vw, 2.1rem);
    line-height: 1.15;
    margin: 14px 0;
  }

  .benefit-copy > p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 1.02rem;
    line-height: 1.6;
  }

  .benefit-checks {
    list-style: none;
    padding: 0;
    margin: 26px 0 0;
    display: grid;
    gap: 14px;
  }

  .benefit-checks li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-weight: 600;
    color: var(--ink);
  }

  .benefit-check-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--brand-tint);
    color: var(--brand);
  }

  .benefit-check-icon svg {
    width: 13px;
    height: 13px;
  }

  @media (max-width: 860px) {
    .benefit-card {
      position: static;
      grid-template-columns: 1fr;
      gap: 28px;
      padding: 22px;
    }
    .benefit-card.reverse .benefit-visual {
      order: 0;
    }
    .benefit-visual {
      padding: 28px;
      min-height: 240px;
    }
    .benefit-copy {
      padding: 0 4px;
    }
    .benefit-stack {
      gap: 24px;
    }
  }

  .mk {
    position: relative;
    width: 100%;
  }

  .mk-browser {
    border-radius: 12px;
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow-md);
    overflow: hidden;
  }

  .mk-bar {
    display: flex;
    gap: 6px;
    padding: 10px 12px;
    background: var(--surface-soft);
    border-bottom: 1px solid var(--line);
  }

  .mk-bar span {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--line);
  }

  .mk-screen {
    display: grid;
    justify-items: center;
    gap: 9px;
    padding: 26px 20px 30px;
    background: linear-gradient(
      160deg,
      var(--brand-tint),
      var(--surface)
    );
  }

  .mk-pill {
    font-size: 0.6rem;
    font-weight: 800;
    color: var(--brand);
    background: var(--surface);
    border: 1px solid var(--line);
    padding: 3px 9px;
    border-radius: 999px;
  }

  .mk-h {
    width: 58%;
    height: 13px;
    border-radius: 6px;
    background: var(--ink);
    opacity: 0.85;
  }

  .mk-line {
    width: 70%;
    height: 7px;
    border-radius: 999px;
    background: var(--line);
  }

  .mk-line.mk-sm {
    width: 48%;
  }

  .mk-btn {
    margin-top: 6px;
    font-size: 0.62rem;
    font-weight: 800;
    color: #fff;
    background: var(--brand);
