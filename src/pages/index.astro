---

<Layout>
  <!-- 1. Hero -->
  <section class="hero">
    <PrismBg />
    <div class="container hero-inner text-center">
      <p class="hero-tagline anim-in" style="--delay: 0ms;">
        Built for contractors who want a stacked business.
      </p>
      <h1 class="anim-in" style="--delay: 60ms;">
        Load Fast. <span class="hl">Rank High.</span> Get Paid.
      </h1>
      <p class="lead hero-lead anim-in" style="--delay: 200ms;">
        Stacked builds done-for-you websites that load fast, rank on Google, and
        send every new lead straight to your phone by text. Live in days, not
        months.
      </p>
      <div class="hero-actions anim-in" style="--delay: 340ms;">
        <a href="/contact" class="btn btn-primary">Book Call</a>
        <a href="#features" class="btn btn-outline">See features</a>
      </div>

      <div class="hero-trust anim-in" style="--delay: 460ms;">
        <div class="hero-trust-rating">
          <span class="hero-trust-stars">★★★★★</span>
          <span class="hero-trust-score">4.4</span>
          <span class="hero-trust-label">Excellent on Trustpilot</span>
        </div>
        <span class="hero-trust-divider"></span>
        <div class="hero-trust-avatars">
          <span class="avatar-stack">
            <img class="avatar" src="/avatars/c1.jpg" alt="" width="26" height="26" loading="lazy" />
            <img class="avatar" src="/avatars/c2.jpg" alt="" width="26" height="26" loading="lazy" />
            <img class="avatar" src="/avatars/c3.jpg" alt="" width="26" height="26" loading="lazy" />
            <img class="avatar" src="/avatars/c4.jpg" alt="" width="26" height="26" loading="lazy" />
          </span>
          <span class="hero-trust-label">Trusted by 500+ contractors</span>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="hero-visual anim-pop" style="--delay: 480ms;" aria-hidden="true">
        <div class="hero-tilt">
          <video
            class="hero-shot"
            src="/FullSizeRender_optimized.mp4"
            poster="/FullSizeRender_first_frame.png"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            disablepictureinpicture
            aria-hidden="true"
          ></video>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Trusted by — logo marquee -->
  <section class="trusted">
    <div class="container text-center">
      <p class="trusted-label" data-reveal>
        Trusted by contractors in every trade
      </p>
    </div>
    <div class="logo-marquee" aria-label="Companies that trust Stacked">
      <div class="logo-track">
        {
          [...clientLogos, ...clientLogos].map((c) => (
            <span class="logo-item">
              <img class="logo-img" src={c.src} alt={c.name} loading="lazy" />
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Featured pull-quote — light band, blue text -->
  <section class="pquote">
    <div class="container">
      <div class="pquote-panel" data-reveal>
        <span class="pquote-glow" aria-hidden="true"></span>
        <div class="pquote-inner">
          <div class="pquote-stars" aria-label="5 out of 5 stars">
            <span class="pquote-star">★</span><span class="pquote-star">★</span><span class="pquote-star">★</span><span class="pquote-star">★</span><span class="pquote-star">★</span>
          </div>
          <p class="pquote-text">
            {
              "It took me 15 minutes to set up. A few days later I had |4–7 leads a day| texted straight to my phone. I think I'll double revenue this month."
                .split("|")
                .map((chunk, ci) =>
                  chunk.split(" ").filter(Boolean).map((w) => (
                    <Fragment>
                      <span class:list={["pquote-word", { "pquote-hl": ci === 1 }]}>{w}</span>{" "}
                    </Fragment>
                  ))
                )
            }
          </p>
          <div class="pquote-author">
            <span class="pquote-face" style="background:#0f766e;">GR</span>
            <div class="pquote-id">
              <div class="pquote-name">Glenn Robertson</div>
              <div class="pquote-role">Founder · Texas State Builders</div>
            </div>
            <span class="pquote-src" aria-label="Google review">
              <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path fill="#4285F4" d="M23.5 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.5c-.3 1.5-1.1 2.7-2.4 3.6v3h3.9c2.3-2.1 3.5-5.2 3.5-8.8z" />
                <path fill="#34A853" d="M12 24c3.2 0 6-1.1 8-2.9l-3.9-3c-1.1.7-2.5 1.2-4.1 1.2-3.1 0-5.8-2.1-6.7-5H1.3v3.1C3.3 21.3 7.3 24 12 24z" />
                <path fill="#FBBC05" d="M5.3 14.3c-.2-.7-.4-1.5-.4-2.3s.1-1.6.4-2.3V6.6H1.3C.5 8.2 0 10 0 12s.5 3.8 1.3 5.4l4-3.1z" />
                <path fill="#EA4335" d="M12 4.8c1.8 0 3.3.6 4.6 1.8l3.4-3.4C18 1.2 15.2 0 12 0 7.3 0 3.3 2.7 1.3 6.6l4 3.1C6.2 6.9 8.9 4.8 12 4.8z" />
              </svg>
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEW: Product showcase / demo -->
  <section class="section showcase-section">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <h2>The actual product, not a promise</h2>
        <p class="lead" style="margin: 0 auto;">
          Here's a real contractor site built on Stacked: fast, modern, and
          wired to send every lead straight to the owner's phone.
        </p>
      </div>

      <div class="showcase-layout" data-reveal>
        <div class="showcase-phone-wrap">
          <div class="device device-iphone-14-pro device-silver showcase-iphone">
            <div class="device-frame">
              <div class="ios-screen">
                <!-- iOS status bar -->
                <div class="ios-statusbar">
                  <span class="ios-time">9:41</span>
                  <div class="ios-status-right">
                    <svg class="ios-signal" viewBox="0 0 18 12" aria-hidden="true">
                      <rect x="0" y="8" width="3" height="4" rx="1"></rect>
                      <rect x="5" y="5.5" width="3" height="6.5" rx="1"></rect>
                      <rect x="10" y="3" width="3" height="9" rx="1"></rect>
                      <rect x="15" y="0.5" width="3" height="11.5" rx="1"></rect>
                    </svg>
                    <svg class="ios-wifi" viewBox="0 0 16 12" aria-hidden="true">
                      <path d="M8 11.2 9.6 9.3a2.1 2.1 0 0 0-3.2 0L8 11.2Z"></path>
                      <path d="M8 7.2a4.6 4.6 0 0 1 3.5 1.6l1.3-1.5a6.6 6.6 0 0 0-9.6 0l1.3 1.5A4.6 4.6 0 0 1 8 7.2Z" opacity="0.95"></path>
                      <path d="M8 3.2a8.7 8.7 0 0 1 6.4 2.8L15.7 4.5a10.7 10.7 0 0 0-15.4 0L1.6 6A8.7 8.7 0 0 1 8 3.2Z" opacity="0.95"></path>
                    </svg>
                    <span class="ios-battery">
                      <span class="ios-battery-level"></span>
                    </span>
                  </div>
                </div>

                <!-- iOS notification banner — slides down on scroll -->
                <div class="ios-notification" aria-hidden="true">
                  <span class="ios-notif-icon">
                    <svg viewBox="165 115 430 350" aria-hidden="true">
                      <g fill="#fff">
                        <path d="M275 124.5H579C592.531 124.5 603.5 135.469 603.5 149V373C603.5 386.531 592.531 397.5 579 397.5H275C261.469 397.5 250.5 386.531 250.5 373V149C250.5 135.469 261.469 124.5 275 124.5Z" />
                        <path d="M235 164.5H539C552.531 164.5 563.5 175.469 563.5 189V413C563.5 426.531 552.531 437.5 539 437.5H235C221.469 437.5 210.5 426.531 210.5 413V189C210.5 175.469 221.469 164.5 235 164.5Z" stroke="#1d4ed8" stroke-width="18" stroke-linejoin="round" />
                        <path d="M195 204.5H499C512.531 204.5 523.5 215.469 523.5 229V453C523.5 466.531 512.531 477.5 499 477.5H195C181.469 477.5 170.5 466.531 170.5 453V229C170.5 215.469 181.469 204.5 195 204.5Z" stroke="#1d4ed8" stroke-width="18" stroke-linejoin="round" />
                      </g>
                    </svg>
                  </span>
                  <div class="ios-notif-body">
                    <div class="ios-notif-top">
                      <span class="ios-notif-app">Stacked</span>
                      <span class="ios-notif-time">now</span>
                    </div>
                    <span class="ios-notif-title">New lead from John D.</span>
                    <span class="ios-notif-text">Inquiry: I'd like a quote for Vuba Stone surfacing.</span>
                  </div>
                </div>

                <!-- Live client site — Lakes Area Surfacing (rebuilt from site markup) -->
                <div class="ios-content las">
                  <section class="las-hero">
                    <div class="las-hero-overlay"></div>
                    <header class="las-head">
                      <a class="las-brand">
                        <img class="las-logo" src="/sites/las-logo.webp" alt="Lakes Area Surfacing" />
                        <span>Lakes Area Surfacing</span>
                      </a>
                      <span class="las-cta">Get a Free Estimate</span>
                    </header>
                    <div class="las-hero-inner">
                      <p class="las-eyebrow">Brainerd, MN</p>
                      <h1 class="las-headline">Professional<br />Vuba Stone<br />Surfacing</h1>
                      <p class="las-sub">Expert Vuba Stone installation for driveways, patios, and commercial spaces built to perform and impress</p>
                      <div class="las-btns">
                        <span class="las-btn-white">Get a Free Estimate</span>
                        <span class="las-btn-outline">(218) 841-4137</span>
                      </div>
                    </div>
                  </section>
                </div>

                <!-- Safari dynamic bottom bar -->
                <div class="ios-safari">
                  <!-- URL bar row -->
                  <div class="safari-url">
                    <span class="safari-url-left">
                      <svg class="safari-reader" viewBox="0 0 18 16" aria-hidden="true">
                        <rect x="1" y="2" width="16" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.3"></rect>
                        <line x1="4" y1="14.5" x2="14" y2="14.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></line>
                      </svg>
                      <svg class="safari-eye" viewBox="0 0 20 16" aria-hidden="true">
                        <path d="M2 8s2.8-5 8-5 8 5 8 5-2.8 5-8 5S2 8 2 8Z" fill="none" stroke="currentColor" stroke-width="1.4"></path>
                        <circle cx="10" cy="8" r="2.2" fill="none" stroke="currentColor" stroke-width="1.4"></circle>
                        <line x1="3" y1="14.5" x2="17" y2="1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></line>
                      </svg>
                    </span>
                    <span class="safari-url-center">
                      <svg class="safari-lock" viewBox="0 0 12 14" aria-hidden="true">
                        <rect x="1.5" y="6" width="9" height="7" rx="1.5"></rect>
                        <path d="M3.5 6V4a2.5 2.5 0 0 1 5 0v2" fill="none" stroke="currentColor" stroke-width="1.3"></path>
                      </svg>
                      <span class="safari-host">lakesareasurfacing.com</span>
                    </span>
                    <svg class="safari-refresh" viewBox="0 0 14 14" aria-hidden="true">
                      <path d="M12 7a5 5 0 1 1-1.5-3.5M12 1v3H9" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </div>

                  <!-- Toolbar row -->
                  <div class="safari-toolbar">
                    <button class="safari-tb safari-disabled" aria-label="Back">
                      <svg viewBox="0 0 16 22" aria-hidden="true">
                        <path d="M11 4 5 11l6 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
