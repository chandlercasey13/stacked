  ],
  // Row B — scrolls right
  [
    { mono: "DW", bg: "#7c3aed", name: "Diana Walsh", role: "Owner · Whitfield HVAC", src: "google", stars: "★★★★★", quote: "We stopped missing calls. The text-back feature alone has paid for itself ten times over." },
    { face: "/avatars/c4.jpg", name: "Paul Nguyen", role: "Founder · TrueLine Electric", src: "google", stars: "★★★★★", quote: "Ranked on the first page of Google in under a month. My phone hasn't stopped since." },
    { mono: "VC", bg: "#0369a1", name: "Veronica Castro", role: "Owner · Evergreen Landscapes", src: "trustpilot", stars: "★★★★☆", quote: "Clean, fast, and easy to update myself. And support actually answers when I reach out." },
    { mono: "HG", bg: "#be123c", name: "Haley Griffin", role: "Owner · Hart Plumbing", src: "google", stars: "★★★★★", quote: "Best money I spend each month. The reviews funnel took us from 18 to 120 Google reviews." },
    { mono: "WT", bg: "#15803d", name: "Will Tanaka", role: "Owner · Oakwood Exteriors", src: "trustpilot", stars: "★★★★★", quote: "Looks more professional than competitors who've been around for 20 years. Worth every penny." },
  ],
];

// Source badge SVGs (Google / Trustpilot)
const srcBadge = {
  google: `<svg viewBox="0 0 24 24" width="26" height="26"><path fill="#4285F4" d="M23.5 12.3c0-.8-.1-1.6-.2-2.3H12v4.5h6.5c-.3 1.5-1.1 2.7-2.4 3.6v3h3.9c2.3-2.1 3.5-5.2 3.5-8.8z"/><path fill="#34A853" d="M12 24c3.2 0 6-1.1 8-2.9l-3.9-3c-1.1.7-2.5 1.2-4.1 1.2-3.1 0-5.8-2.1-6.7-5H1.3v3.1C3.3 21.3 7.3 24 12 24z"/><path fill="#FBBC05" d="M5.3 14.3c-.2-.7-.4-1.5-.4-2.3s.1-1.6.4-2.3V6.6H1.3C.5 8.2 0 10 0 12s.5 3.8 1.3 5.4l4-3.1z"/><path fill="#EA4335" d="M12 4.8c1.8 0 3.3.6 4.6 1.8l3.4-3.4C18 1.2 15.2 0 12 0 7.3 0 3.3 2.7 1.3 6.6l4 3.1C6.2 6.9 8.9 4.8 12 4.8z"/></svg>`,
  trustpilot: `<svg viewBox="0 0 24 24" width="26" height="26"><rect width="24" height="24" rx="5" fill="#00B67A"/><path fill="#fff" d="M12 4.5l1.8 5.4h5.7l-4.6 3.3 1.8 5.4L12 15.3l-4.5 3.3 1.8-5.4-4.6-3.3h5.7z"/></svg>`,
};

// Blog / ideas
const posts = [
  {
    tag: "Featured",
    title: "How contractors win more local leads in 2026",
    kind: "Must Read",
  },
  { tag: "Speed", title: "Why a slow website is costing you jobs", kind: "Tips" },
  {
    tag: "Reviews",
    title: "Turning happy customers into 5-star reviews",
    kind: "Growth",
  },
  {
    tag: "Follow-up",
    title: "Answer the phone or text back? What converts more",
    kind: "Sales",
  },
];
---

<Layout>
  <!-- 1. Hero -->
  <section class="hero">
    <PrismBg />
    <div class="container hero-inner text-center">
      <p class="hero-tagline anim-in" style="--delay: 0ms;">
        Built for contractors who want a stacked business.
      </p>
      <h1 class="anim-in" style="--delay: 60ms;">
        Load Fast. <span class="hl">Rank High.</span> Get Paid.
      </h1>
      <p class="lead hero-lead anim-in" style="--delay: 200ms;">
        Stacked builds done-for-you websites that load fast, rank on Google, and
        send every new lead straight to your phone by text. Live in days, not
        months.
      </p>
      <div class="hero-actions anim-in" style="--delay: 340ms;">
        <a href="/contact" class="btn btn-primary">Book Call</a>
        <a href="#features" class="btn btn-outline">See features</a>
      </div>

      <div class="hero-trust anim-in" style="--delay: 460ms;">
        <div class="hero-trust-rating">
          <span class="hero-trust-stars">★★★★★</span>
          <span class="hero-trust-score">4.4</span>
          <span class="hero-trust-label">Excellent on Trustpilot</span>
        </div>
        <span class="hero-trust-divider"></span>
        <div class="hero-trust-avatars">
          <span class="avatar-stack">
            <img class="avatar" src="/avatars/c1.jpg" alt="" width="26" height="26" loading="lazy" />
            <img class="avatar" src="/avatars/c2.jpg" alt="" width="26" height="26" loading="lazy" />
            <img class="avatar" src="/avatars/c3.jpg" alt="" width="26" height="26" loading="lazy" />
            <img class="avatar" src="/avatars/c4.jpg" alt="" width="26" height="26" loading="lazy" />
          </span>
          <span class="hero-trust-label">Trusted by 500+ contractors</span>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="hero-visual anim-pop" style="--delay: 480ms;" aria-hidden="true">
        <div class="hero-tilt">
          <video
            class="hero-shot"
            src="/FullSizeRender_optimized.mp4"
            poster="/FullSizeRender_first_frame.png"
            autoplay
            loop
            muted
            playsinline
            preload="auto"
            disablepictureinpicture
            aria-hidden="true"
          ></video>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Trusted by — logo marquee -->
  <section class="trusted">
    <div class="container text-center">
      <p class="trusted-label" data-reveal>
        Trusted by contractors in every trade
      </p>
    </div>
    <div class="logo-marquee" aria-label="Companies that trust Stacked">
      <div class="logo-track">
        {
          [...clientLogos, ...clientLogos].map((c) => (
            <span class="logo-item" aria-hidden="false">
              <svg class="logo-mark" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M3 21V10l9-6 9 6v11" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                <path d="M9 21v-6h6v6" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="logo-name">{c.name}</span>
            </span>
          ))
        }
      </div>
    </div>
  </section>

  <!-- NEW: Product showcase / demo -->
  <section class="section showcase-section">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <h2>The actual product, not a promise</h2>
        <p class="lead" style="margin: 0 auto;">
          Here's a real contractor site built on Stacked — fast, modern, and
          wired to send every lead straight to the owner's phone.
        </p>
      </div>

      <div class="showcase-layout" data-reveal>
        <div class="showcase-phone-wrap">
          <div class="device device-iphone-14-pro device-silver showcase-iphone">
            <div class="device-frame">
              <div class="ios-screen">
                <!-- iOS status bar -->
                <div class="ios-statusbar">
                  <span class="ios-time">9:41</span>
                  <div class="ios-status-right">
                    <svg class="ios-signal" viewBox="0 0 18 12" aria-hidden="true">
                      <rect x="0" y="8" width="3" height="4" rx="1"></rect>
                      <rect x="5" y="5.5" width="3" height="6.5" rx="1"></rect>
                      <rect x="10" y="3" width="3" height="9" rx="1"></rect>
                      <rect x="15" y="0.5" width="3" height="11.5" rx="1"></rect>
                    </svg>
                    <svg class="ios-wifi" viewBox="0 0 16 12" aria-hidden="true">
                      <path d="M8 11.2 9.6 9.3a2.1 2.1 0 0 0-3.2 0L8 11.2Z"></path>
                      <path d="M8 7.2a4.6 4.6 0 0 1 3.5 1.6l1.3-1.5a6.6 6.6 0 0 0-9.6 0l1.3 1.5A4.6 4.6 0 0 1 8 7.2Z" opacity="0.95"></path>
                      <path d="M8 3.2a8.7 8.7 0 0 1 6.4 2.8L15.7 4.5a10.7 10.7 0 0 0-15.4 0L1.6 6A8.7 8.7 0 0 1 8 3.2Z" opacity="0.95"></path>
                    </svg>
                    <span class="ios-battery">
                      <span class="ios-battery-level"></span>
                    </span>
                  </div>
                </div>

                <!-- iOS notification banner — slides down on scroll -->
                <img
                  class="ios-notification"
                  src="/notification.webp"
                  alt="New lead notification"
                  aria-hidden="true"
                />

                <!-- Mattila Companies — faithful mobile replica (sport theme) -->
                <div class="ios-content mc">
                  <!-- Header -->
                  <header class="mc-header">
                    <a class="mc-brand">
                      <img src="/stacked-icon.png" alt="Mattila Companies" />
                    </a>
                    <a class="mc-cta">Request a Project Quote</a>
                    <button class="mc-hamburger" aria-label="Open menu">
                      <span></span><span></span><span></span>
                    </button>
                  </header>

                  <!-- Hero -->
                  <section class="mc-hero">
                    <div class="mc-hero-overlay"></div>
                    <div class="mc-hero-content">
                      <h1 class="mc-headline">Luxury Outdoor Living &amp; Construction Built To Last</h1>
                      <p class="mc-sub">Mattila Companies delivers premium inground pool, hardscape, remodeling, and custom construction services designed to combine durability, craftsmanship, and modern design for properties that stand out.</p>
                      <div class="mc-btns">
                        <a class="mc-btn-white">Request a Project Quote</a>
                        <a class="mc-btn-outline">(763)-742-4697</a>
                      </div>
                    </div>
                  </section>

                  <!-- Services -->
                  <section class="mc-section">
                    <h2 class="mc-section-title">Concrete Craft</h2>
                    <p class="mc-section-sub">From custom concrete and luxury hardscapes to remodels and full home builds, Mattila Companies delivers high-quality craftsmanship.</p>
                    <div class="mc-svc-grid">
                      <a class="mc-svc-card mc-svc-pool">
                        <div class="mc-svc-card-bg"></div>
                        <span class="mc-svc-name">Inground Pools</span>
                      </a>
                      <a class="mc-svc-card mc-svc-concrete">
                        <div class="mc-svc-card-bg"></div>
                        <span class="mc-svc-name">Custom Concrete</span>
                      </a>
                      <a class="mc-svc-card mc-svc-hardscape">
                        <div class="mc-svc-card-bg"></div>
                        <span class="mc-svc-name">Hardscape Design</span>
                      </a>
                    </div>
                  </section>
                </div>

                <!-- Safari dynamic bottom bar -->
                <div class="ios-safari">
                  <!-- URL bar row -->
                  <div class="safari-url">
                    <span class="safari-url-left">
                      <svg class="safari-reader" viewBox="0 0 18 16" aria-hidden="true">
                        <rect x="1" y="2" width="16" height="10" rx="2" fill="none" stroke="currentColor" stroke-width="1.3"></rect>
                        <line x1="4" y1="14.5" x2="14" y2="14.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"></line>
                      </svg>
                      <svg class="safari-eye" viewBox="0 0 20 16" aria-hidden="true">
                        <path d="M2 8s2.8-5 8-5 8 5 8 5-2.8 5-8 5S2 8 2 8Z" fill="none" stroke="currentColor" stroke-width="1.4"></path>
                        <circle cx="10" cy="8" r="2.2" fill="none" stroke="currentColor" stroke-width="1.4"></circle>
                        <line x1="3" y1="14.5" x2="17" y2="1.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"></line>
                      </svg>
                    </span>
                    <span class="safari-url-center">
                      <svg class="safari-lock" viewBox="0 0 12 14" aria-hidden="true">
                        <rect x="1.5" y="6" width="9" height="7" rx="1.5"></rect>
                        <path d="M3.5 6V4a2.5 2.5 0 0 1 5 0v2" fill="none" stroke="currentColor" stroke-width="1.3"></path>
                      </svg>
                      <span class="safari-host">mattilacompanies.com</span>
                    </span>
                    <svg class="safari-refresh" viewBox="0 0 14 14" aria-hidden="true">
                      <path d="M12 7a5 5 0 1 1-1.5-3.5M12 1v3H9" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </div>

                  <!-- Toolbar row -->
                  <div class="safari-toolbar">
                    <button class="safari-tb safari-disabled" aria-label="Back">
                      <svg viewBox="0 0 16 22" aria-hidden="true">
                        <path d="M11 4 5 11l6 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </button>
                    <button class="safari-tb safari-disabled" aria-label="Forward">
                      <svg viewBox="0 0 16 22" aria-hidden="true">
                        <path d="M5 4l6 7-6 7" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </button>
                    <button class="safari-tb safari-accent" aria-label="Share">
                      <svg viewBox="0 0 20 24" aria-hidden="true">
                        <path d="M10 15V3m0 0L6 7m4-4 4 4" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                        <path d="M5 11H4a1 1 0 0 0-1 1v8a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-8a1 1 0 0 0-1-1h-1" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"></path>
                      </svg>
                    </button>
                    <button class="safari-tb safari-accent" aria-label="Bookmarks">
                      <svg viewBox="0 0 22 20" aria-hidden="true">
                        <path d="M3 4a2 2 0 0 1 2-2h5v15l-3.5-2L3 17V4Z" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
                        <path d="M11 2h6a2 2 0 0 1 2 2v13l-3.5-2L11 17" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"></path>
                      </svg>
                    </button>
                    <button class="safari-tb safari-accent" aria-label="Tabs">
                      <svg viewBox="0 0 22 20" aria-hidden="true">
                        <rect x="6" y="5" width="13" height="13" rx="2.5" fill="none" stroke="currentColor" stroke-width="1.6"></rect>
                        <path d="M3 14V4a2 2 0 0 1 2-2h9" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"></path>
                      </svg>
                    </button>
                  </div>

                  <!-- iOS home indicator (inside the Safari chrome) -->
                  <span class="ios-home-indicator" aria-hidden="true"></span>
                </div>
              </div>
            </div>
            <div class="device-stripe"></div>
            <div class="device-header"></div>
            <div class="device-sensors"></div>
            <div class="device-btns"></div>
            <div class="device-power"></div>
          </div>
          <div class="iphone-glow" aria-hidden="true"></div>
        </div>

        <div class="showcase-copy">
          <h2 class="showcase-heading">Built to Get You Paid</h2>
          <p class="showcase-sub"><em>Get a website that instantly turns leads into text conversations that go directly to your phone.</em></p>
          <ul class="showcase-callouts">
            {
              showcaseCallouts.map((c) => (
                <li class="showcase-callout">
                  <span class="showcase-check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M20 6 9 17l-5-5" />
                    </svg>
                  </span>
                  <div>
                    <strong>{c.title}</strong>
                    <p>{c.text}</p>
                  </div>
                </li>
              ))
            }
          </ul>
          <a href="/contact" class="btn btn-primary showcase-cta">Book a Call</a>
        </div>
      </div>
    </div>
  </section>

  <!-- NEW: Benefits — sticky stacking cards -->
  <section class="section benefit-section">
    <div class="container">
      <div class="text-center center-narrow" data-reveal>
        <h2>Experience the <span class="hl">future of your trade</span></h2>
      </div>

      <div class="benefit-stack">
        {
          painPoints.map((p, i) => (
            <article
              class:list={["benefit-card", i % 2 === 1 ? "reverse" : ""]}
              style={`--i: ${i}`}
            >
              <div class="benefit-visual" aria-hidden="true">
                {p.visual === "reviews" && (
                  <div class="mk mk-reviews">
                    <div class="mk-review-card">
                      <span class="mk-review-logo">G</span>
                      <span class="mk-review-q">How did we do?</span>
                      <span class="mk-review-stars">
