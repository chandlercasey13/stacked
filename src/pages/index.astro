  }

  .pd-trust-item:last-child { border-right: 0; }

  .pd-trust-item strong {
    font-size: 15px;
    font-weight: 900;
    display: block;
    line-height: 1;
    margin-bottom: 3px;
  }

  .pd-trust-item span {
    font-size: 8px;
    font-weight: 600;
    opacity: 0.9;
    letter-spacing: 0.02em;
    line-height: 1.2;
    text-align: center;
