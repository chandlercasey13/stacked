    margin: 0 auto;
    background: var(--primary);
    color: #fff;
    font-family: var(--font-body);
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    font-size: 0.7rem;
    padding: 0.3rem 0.65rem;
    white-space: nowrap;
    border-radius: 0;
    line-height: 1.2;
  }

  .mc-hamburger {
    order: 3;
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    padding: 6px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: transparent;
    border: none;
    color: #374151;
  }

  .mc-hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
  }

  /* Hero (sport) */
  .mc-hero {
    position: relative;
    overflow: hidden;
    padding: 7rem 1.25rem 6.5rem;
    text-align: center;
    background: var(--primary) url('/mattila-hero.webp') center / cover no-repeat;
  }

  .mc-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.38);
  }

  .mc-hero-content {
    position: relative;
    z-index: 1;
    max-width: 540px;
    margin: 0 auto;
  }

  .mc-headline {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.04;
    color: #fff;
