<script>
  // Tab pill groups (alternating feature sections)
  document.querySelectorAll<HTMLElement>("[data-tabset]").forEach((set) => {
    const pills = set.querySelectorAll<HTMLElement>(".tab-pill");
    const panels = set.querySelectorAll<HTMLElement>("[data-panel]");
    pills.forEach((pill) => {
      pill.addEventListener("click", () => {
        const idx = pill.getAttribute("data-tab");
        pills.forEach((p) => p.classList.remove("active"));
        pill.classList.add("active");
        panels.forEach((panel) => {
          panel.classList.toggle(
            "active",
            panel.getAttribute("data-panel") === idx
          );
        });
      });
    });
  });

  // Device toggle (phone / web)
  document.querySelectorAll<HTMLElement>("[data-toggle]").forEach((toggle) => {
    const section = toggle.closest("section");
    const btns = toggle.querySelectorAll<HTMLElement>(".device-btn");
    btns.forEach((btn) => {
      btn.addEventListener("click", () => {
        const device = btn.getAttribute("data-device");
        btns.forEach((b) => b.classList.remove("active"));
        btn.classList.add("active");
        section
          ?.querySelectorAll<HTMLElement>("[data-device-panel]")
          .forEach((panel) => {
            panel.classList.toggle(
              "active",
              panel.getAttribute("data-device-panel") === device
            );
          });
      });
    });
  });
</script>
