  .mk-sms-label {
    display: block;
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    color: var(--brand);
    margin-bottom: 3px;
  }

  /* NEW: How it works — alternating timeline */
  .steps-timeline {
    position: relative;
    list-style: none;
    margin: 72px auto 0;
    padding: 0;
    max-width: 940px;
    display: grid;
    gap: 80px;
  }

  /* scroll reveal — slide each row in from its side */
  .steps-row.left[data-reveal] {
    opacity: 0;
    transform: translateX(-48px);
  }

  .steps-row.right[data-reveal] {
    opacity: 0;
    transform: translateX(48px);
  }

  .steps-row[data-reveal].is-visible {
    opacity: 1;
    transform: none;
  }

  .steps-row[data-reveal] .steps-marker {
    opacity: 0;
    transform: scale(0.4);
    transition: opacity 0.5s var(--ease-out) 0.12s,
      transform 0.5s var(--ease-out) 0.12s;
  }

  .steps-row[data-reveal].is-visible .steps-marker {
    opacity: 1;
    transform: scale(1);
  }

  /* center spine */
  .steps-timeline::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--line) 8%,
      var(--line) 92%,
      transparent
    );
    transform: translateX(-50%);
  }

  .steps-row {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 56px 1fr;
    align-items: center;
    column-gap: 12px;
  }

  .steps-card {
    grid-row: 1;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 26px 28px;
    box-shadow: var(--shadow-md);
    position: relative;
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .steps-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  /* little pointer connecting card to the spine */
  .steps-card::after {
    content: "";
    position: absolute;
    top: 50%;
    width: 14px;
    height: 14px;
    background: var(--surface);
    border: 1px solid var(--line);
    transform: translateY(-50%) rotate(45deg);
  }

  .steps-row.left .steps-card {
    grid-column: 1;
    text-align: right;
  }

  .steps-row.left .steps-card::after {
    right: -8px;
    border-left: 0;
    border-bottom: 0;
  }

  .steps-row.right .steps-card {
    grid-column: 3;
    text-align: left;
  }

  .steps-row.right .steps-card::after {
    left: -8px;
    border-right: 0;
    border-top: 0;
  }

  /* center number marker */
  .steps-marker {
    grid-column: 2;
    grid-row: 1;
    justify-self: center;
    z-index: 1;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 1.1rem;
    font-weight: 800;
    color: #fff;
    background: var(--brand);
    border: 4px solid var(--surface-soft);
    box-shadow: 0 0 0 1px var(--line), var(--shadow-sm);
  }

  .steps-eyebrow {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
  }

  .steps-card h3 {
    font-size: 1.3rem;
    margin: 6px 0 8px;
    line-height: 1.2;
  }

  .steps-card p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.6;
    font-size: 0.97rem;
  }

  .steps-stat {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-top: 18px;
  }

  .steps-row.left .steps-stat {
    justify-content: flex-end;
  }

  .steps-stat-value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--brand);
    line-height: 1;
  }

  .steps-stat-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
  }

  @media (max-width: 720px) {
    .steps-timeline {
      gap: 44px;
    }
    .steps-timeline::before {
      left: 27px;
    }
    .steps-row {
      grid-template-columns: 56px 1fr;
      column-gap: 18px;
    }
    .steps-marker {
      grid-column: 1;
      justify-self: start;
    }
    .steps-row.left .steps-card,
    .steps-row.right .steps-card {
      grid-column: 2;
      text-align: left;
    }
    .steps-row.left .steps-stat {
      justify-content: flex-start;
    }
    .steps-row.left .steps-card::after,
    .steps-row.right .steps-card::after {
      left: -8px;
      right: auto;
      border-right: 0;
      border-top: 0;
      border-left: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }
  }

  /* NEW: Product showcase / demo */
  .showcase-layout {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 48px;
    align-items: center;
    margin-top: 48px;
  }

  /* ── devices.css iPhone wrapper ── */
  .showcase-phone-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 48px 24px;
  }

  .iphone-glow {
    position: absolute;
    bottom: -10%;
    left: 5%;
    right: 5%;
    height: 55%;
    background: radial-gradient(ellipse at 50% 100%, color-mix(in srgb, var(--brand) 55%, transparent) 0%, transparent 70%);
    filter: blur(40px);
    z-index: 2;
    pointer-events: none;
  }

  @keyframes phoneSlideUp {
    from {
      opacity: 0;
      translate: 0 60px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .showcase-iphone {
    /* scale down the 868×428 native size to fit the column */
    transform: scale(0.62) perspective(1000px) rotateY(0deg) rotateX(4deg);
    transform-origin: center center;
    transition: transform 0.4s ease;
    position: relative;
    z-index: 1;
    /* preserve intrinsic size so layout isn't affected */
    margin: calc(868px * -0.19) calc(428px * -0.19);
    animation: phoneSlideUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .showcase-iphone:hover {
    transform: scale(0.62) perspective(1000px) rotateY(0deg) rotateX(2deg);
  }

  .showcase-iphone .device-screen {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  /* Force true black metal — override devices.css pink/purple tint */
  .showcase-iphone .device-frame {
    background: #050505;
    border-color: #1a1a1a;
    box-shadow: inset 0 0 4px 2px #333, inset 0 0 0 6px #1c1c1e;
  }

  .showcase-iphone .device-btns,
  .showcase-iphone .device-btns::before,
  .showcase-iphone .device-btns::after,
  .showcase-iphone .device-power {
    background: #1c1c1e;
  }

  .showcase-callouts {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 22px;
  }

  .showcase-callout {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .showcase-callout strong {
    display: block;
    font-size: 1.05rem;
    margin-bottom: 4px;
  }

  .showcase-callout p {
    margin: 0;
    font-size: 0.95rem;
  }

  @media (max-width: 860px) {
    .showcase-layout {
      grid-template-columns: 1fr;
    }
    .showcase-iphone {
      transform: scale(0.4) perspective(1000px) rotateY(0deg) rotateX(3deg);
      margin: calc(868px * -0.3) calc(428px * -0.3);
    }
  }

  /* 1. Hero */
  .hero {
