    font-size: 10px;
    color: rgba(255,255,255,0.7);
    margin: 0 0 4px;
  }

  .pd-cta-band .pd-btn-primary {
    border-color: #c8811a;
  }

  /* Force true black metal — override devices.css pink/purple tint */
  /* Light mode — silver metal rail with a black front bezel.
     border = silver rail edge, inset highlight = silver rim,
     6px inner ring + face = black bezel around the screen. */
  .showcase-iphone .device-frame {
    background: #050505;
    border-color: #c8cacb;
    box-shadow: inset 0 0 4px 2px #e2e3e4, inset 0 0 0 6px #050505;
    /* contain the screen's z-indexes so the status bar can't paint
       over the Dynamic Island, which renders as a sibling above the frame */
    isolation: isolate;
  }

  /* Dark mode — black metal */
  :global([data-theme="dark"]) .showcase-iphone .device-frame {
    background: #050505;
    border-color: #1a1a1a;
    box-shadow: inset 0 0 4px 2px #333, inset 0 0 0 6px #1c1c1e;
  }

  /* keep the Dynamic Island / sensors above the screen chrome */
  .showcase-iphone .device-header,
  .showcase-iphone .device-sensors {
    z-index: 5;
  }

  /* Side buttons — silver in light mode */
  .showcase-iphone .device-btns,
  .showcase-iphone .device-btns::before,
  .showcase-iphone .device-btns::after,
  .showcase-iphone .device-power {
    background: #b4b4b8;
  }

  /* Side buttons — dark in dark mode */
  :global([data-theme="dark"]) .showcase-iphone .device-btns,
  :global([data-theme="dark"]) .showcase-iphone .device-btns::before,
  :global([data-theme="dark"]) .showcase-iphone .device-btns::after,
  :global([data-theme="dark"]) .showcase-iphone .device-power {
    background: #1c1c1e;
  }

  .showcase-copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .showcase-heading {
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    line-height: 1.15;
    margin: 0 0 14px;
  }

  .showcase-sub {
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 28px;
  }

  .showcase-callouts {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: grid;
    gap: 20px;
  }

  .showcase-callout {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .showcase-check {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--brand);
    color: #fff;
    margin-top: 2px;
  }

  .showcase-check svg {
    width: 14px;
    height: 14px;
  }

  .showcase-callout strong {
    display: block;
    font-size: 1.05rem;
    color: var(--brand);
    margin-bottom: 4px;
  }

  .showcase-callout p {
    margin: 0;
    font-size: 0.93rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .showcase-cta {
    align-self: flex-start;
  }

  @media (max-width: 860px) {
    .showcase-layout {
      grid-template-columns: 1fr;
    }
    .showcase-iphone {
      transform: scale(0.52) perspective(1000px) rotateY(0deg) rotateX(1deg);
      margin: calc(868px * -0.24) calc(428px * -0.24);
    }
  }

  /* 1. Hero */
  .hero {
    background: var(--surface-soft);
    padding: calc(72px + 90px) 0 0;
    margin-top: -72px;
    border-bottom: 1px solid var(--line);
    overflow: hidden;
    position: relative;
  }

  :global([data-theme="dark"]) .hero {
    background: var(--bg);
  }

  .hero > .container {
    position: relative;
    z-index: 1;
  }

  .hero-inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    isolation: isolate;
  }

  .hero-tagline {
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brand);
    margin: 0 0 14px;
  }

  .hero-inner h1 {
    font-size: clamp(1.6rem, 4.4vw, 3.5rem);
    white-space: nowrap;
  }


  .hero-lead {
    margin: 0 auto;
  }

  .hl {
    background: linear-gradient(120deg, var(--brand), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    margin: 28px 0 0;
  }

  .hero-trust {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-top: 32px;
    padding: 10px 20px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid var(--line);
    border-radius: 999px;
    backdrop-filter: blur(8px);
    white-space: nowrap;
  }

  .hero-trust-rating {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .hero-trust-stars {
    color: #f59e0b;
    font-size: 0.85rem;
    letter-spacing: -0.5px;
  }

  .hero-trust-score {
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--ink);
  }

  .hero-trust-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .hero-trust-divider {
    width: 1px;
    height: 18px;
    background: var(--line);
    flex-shrink: 0;
  }

  .hero-trust-avatars {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .avatar-stack {
    display: flex;
  }

  .avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--surface-soft);
    border: 2px solid var(--surface);
    margin-left: -6px;
    flex-shrink: 0;
  }

  .avatar:first-child { margin-left: 0; }

  .hero-trust-trades {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-trade-chip {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ink-soft);
    background: var(--surface-soft);
    border: 1px solid var(--line);
    padding: 3px 10px;
    border-radius: 999px;
  }

  @media (max-width: 640px) {
    .hero-trust-divider { display: none; }
    .hero-trust { border-radius: 20px; }
  }

  /* Browser mockup */
  .hero-visual {
    margin-top: 24px;
  }

  .hero-tilt {
    transform: perspective(1800px) rotateX(18deg) scale(0.88, 0.88);
    transform-origin: 50% 50%;
    will-change: transform;
    max-width: 1340px;
    margin: 0 auto;
  }

  .hero-shot {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    pointer-events: none;
  }

  /* 2. Trusted */
  .trusted {
    padding: 40px 0;
    border-bottom: 1px solid var(--line);
  }

  .trusted-label {
    color: var(--muted);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 18px;
  }

  /* Logo marquee */
  .logo-marquee {
    position: relative;
    margin-top: 6px;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
  }

  .logo-track {
    display: flex;
    width: max-content;
    gap: 56px;
    padding: 20px 28px;
    animation: logoScroll 60s linear infinite;
  }

  .logo-marquee:hover .logo-track {
    animation-play-state: paused;
  }

  .logo-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--muted);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .logo-item:hover {
    color: var(--ink);
  }

  .logo-mark {
    width: 30px;
    height: 30px;
    flex-shrink: 0;
  }

  .logo-name {
    font-weight: 800;
    font-size: 1.3rem;
    letter-spacing: -0.02em;
  }

  @keyframes logoScroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  .surface-soft {
    background: var(--surface-soft);
  }


  /* 6. Features */
  .feature-list {
    display: grid;
    gap: 72px;
    margin-top: 56px;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .feature-row.reverse .feature-visual {
    order: -1;
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
    display: grid;
    gap: 10px;
  }

  .check-list li {
    position: relative;
    padding-left: 30px;
    font-weight: 500;
    color: var(--ink);
  }

  .check-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    background: rgba(37, 99, 235, 0.12);
    color: var(--brand);
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .feature-visual {
    display: grid;
    place-items: center;
  }

  .visual-card {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    background: radial-gradient(
        500px 300px at 30% 0%,
        rgba(37, 99, 235, 0.18),
        transparent
      ),
      linear-gradient(160deg, #131d33, #0b1120);
    display: grid;
    place-content: center;
    justify-items: center;
    gap: 14px;
    box-shadow: var(--shadow-lg);
  }

  .visual-icon {
    font-size: 3.5rem;
  }

  .visual-title {
    color: #fff;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Devices showcase */
  .devices-frame {
    position: relative;
    margin-top: 40px;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--surface-soft);
    min-height: 520px;
  }

  .devices-panels {
    position: relative;
    width: 100%;
    min-height: 520px;
  }

  .devices-panel {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 40px 90px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .devices-panel[data-panel="phone"],
  .devices-panel[data-panel="web"] {
    padding: 0;
  }

  .devices-panel.active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .devices-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }


  /* browser scene */
  .devices-browser-scene {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 720px;
  }

  .devices-browser {
    width: 100%;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .devices-browser-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    background: var(--surface-soft);
    border-bottom: 1px solid var(--line);
  }

  .devices-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--line);
    flex-shrink: 0;
  }

  .devices-url {
    margin-left: 10px;
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 14px;
  }

  .devices-browser-body {
    padding: 28px 28px 36px;
  }

  .devices-dash-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .devices-dash-title {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--ink);
  }

  .devices-dash-badge {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--brand);
    background: var(--brand-tint);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .devices-dash-rows {
    display: grid;
    gap: 10px;
  }

  .devices-dash-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 10px;
    font-size: 0.9rem;
    color: var(--ink);
    background: var(--surface-soft);
  }

  .devices-dash-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand);
    flex-shrink: 0;
  }

  /* floating toggle */
  .devices-toggle {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: inline-flex;
    gap: 4px;
    padding: 5px;
    background: color-mix(in srgb, var(--ink) 88%, transparent);
    border-radius: 10px;
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow-lg);
    z-index: 2;
  }

  .devices-btn {
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
    padding: 9px 22px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease;
    white-space: nowrap;
  }

  .devices-btn.active {
    background: #fff;
    color: #0f1218;
  }

  @media (max-width: 640px) {
    .devices-frame {
      min-height: 460px;
    }
    .devices-panel {
      padding: 40px 16px 80px;
    }
    .devices-phone {
      width: 220px;
    }
  }

  /* 7. Testimonials — stacked deck of review cards */
  .tstack-wrap {
    max-width: 600px;
    margin: 52px auto 0;
  }

  .tstack {
    position: relative;
    min-height: 360px;
  }

  .tcard {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 30px 32px;
    box-shadow: 0 30px 55px -30px rgba(15, 23, 42, 0.32);
    transform-origin: top center;
    transition:
      transform 0.5s var(--ease-out),
      opacity 0.4s var(--ease-out);
    cursor: pointer;
    will-change: transform, opacity;
  }

  .tcard-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 26px;
  }

  .tcard-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 0;
  }

  .tcard-logo {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 11px;
    display: grid;
    place-items: center;
    font-weight: 800;
    font-size: 1.05rem;
    color: #fff;
    background: linear-gradient(135deg, var(--brand), var(--accent));
  }

  .tcard-company {
    font-weight: 800;
    font-size: 1.12rem;
    letter-spacing: -0.01em;
    color: var(--ink);
    line-height: 1.2;
  }

  .tcard-source {
    flex-shrink: 0;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: grid;
    place-items: center;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    color: var(--muted);
  }

  .tcard-mark {
    width: 17px;
    height: 13px;
  }

  .tcard-stars {
    display: flex;
    gap: 3px;
    font-size: 1.05rem;
    margin-bottom: 16px;
    line-height: 1;
  }

  .tcard-star {
    color: #d8dee6;
  }

  .tcard-star.on {
    color: #f5a623;
  }

  .tcard-quote {
    margin: 0;
    color: var(--ink-soft);
    font-size: 1.04rem;
    line-height: 1.55;
  }

  .tcard-foot {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
    padding-top: 30px;
  }

  .tcard-author {
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .tcard-name {
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
  }

  .tcard-role {
    font-size: 0.82rem;
    color: var(--muted);
  }

  .tcard-rating {
    flex-shrink: 0;
    font-size: 0.95rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
  }

  .tstack-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 18px;
    margin-top: 38px;
  }

  .tstack-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--line);
    background: var(--surface);
    color: var(--ink);
    cursor: pointer;
    display: grid;
    place-items: center;
    transition:
      background 0.15s ease,
      border-color 0.15s ease,
      transform 0.15s ease;
  }

  .tstack-arrow:hover {
    background: var(--brand);
    border-color: var(--brand);
    color: #fff;
    transform: translateY(-2px);
  }

  .tstack-arrow svg {
    width: 20px;
    height: 20px;
  }

  .tstack-dots {
    display: flex;
    align-items: center;
    gap: 9px;
  }

  .tstack-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    border: 0;
    padding: 0;
    cursor: pointer;
    background: color-mix(in srgb, var(--ink) 22%, transparent);
    transition:
      background 0.2s ease,
      transform 0.2s ease;
  }

  .tstack-dot.is-active {
    background: var(--brand);
    transform: scale(1.25);
  }

  /* 8. Pricing */
  .home-pricing {
    display: grid;
    grid-template-columns: minmax(0, 400px);
    gap: 28px;
    justify-content: center;
    align-items: start;
    margin-top: 48px;
  }

  .plan {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 34px 30px;
    box-shadow: var(--shadow-sm);
  }

  .plan.featured {
    border-color: var(--brand);
    box-shadow: var(--shadow-lg);
  }

  .badge {
    position: absolute;
    top: -13px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--brand);
    color: #fff;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 6px 14px;
    border-radius: 999px;
  }

  .plan-name {
    font-size: 1.3rem;
  }

  .plan-blurb {
    min-height: 48px;
    margin-bottom: 8px;
  }

  .plan-price {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 20px;
  }

  .amount {
    font-size: 2.6rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .cadence {
    color: var(--muted);
    font-weight: 600;
  }

  .plan-cta {
    width: 100%;
    margin-bottom: 24px;
  }

  .plan-features {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 12px;
  }

  .plan-features li {
    position: relative;
    padding-left: 28px;
    font-size: 0.95rem;
    color: var(--ink);
  }

  .plan-features li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--brand);
    font-weight: 800;
  }

  /* 9. Blog */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .blog-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .blog-card.feature {
    grid-row: span 2;
    grid-column: span 1;
  }

  .blog-thumb {
    aspect-ratio: 16 / 10;
    background: linear-gradient(150deg, var(--brand), var(--accent));
    position: relative;
  }

  .blog-card.feature .blog-thumb {
    aspect-ratio: 16 / 14;
  }

  .blog-tag {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--brand);
    font-weight: 700;
    font-size: 0.74rem;
    padding: 5px 12px;
    border-radius: 999px;
  }

  .blog-body {
    padding: 20px 22px 24px;
  }

  .blog-kind {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .blog-body h3 {
    margin: 8px 0 0;
    font-size: 1.1rem;
  }

  /* 10. Community */
  .community {
    margin-top: 48px;
    gap: 24px;
  }

  .comm-card {
    display: flex;
