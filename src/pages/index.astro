  }

  .mc-sub {
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.78);
    line-height: 1.55;
    margin: 0 auto 2.25rem;
  }

  .mc-btns {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .mc-btn-white {
    width: 100%;
    background: #fff;
