  /* NEW: Product showcase / demo */
  .showcase-layout {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 48px;
    align-items: center;
    margin-top: 56px;
  }

  /* ── devices.css iPhone wrapper ── */
  .showcase-phone-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 48px 24px;
  }

  .iphone-glow {
    position: absolute;
    bottom: -10%;
    left: 5%;
    right: 5%;
    height: 55%;
    background: radial-gradient(ellipse at 50% 100%, color-mix(in srgb, var(--brand) 55%, transparent) 0%, transparent 70%);
    filter: blur(40px);
    z-index: 0;
    pointer-events: none;
  }

  @keyframes phoneSlideUp {
    from {
      opacity: 0;
      translate: 0 60px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .showcase-iphone {
    /* scale down the 868×428 native size to fit the column */
    transform: scale(0.76) perspective(1000px) rotateY(0deg) rotateX(1deg);
    transform-origin: center center;
    transition: transform 0.4s ease;
    position: relative;
    z-index: 1;
    /* preserve intrinsic size so layout isn't affected */
    margin: calc(868px * -0.12) calc(428px * -0.12);
    animation: phoneSlideUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .showcase-iphone:hover {
    transform: scale(0.76) perspective(1000px) rotateY(0deg) rotateX(0deg);
  }

  /* ── iOS screen chrome (status bar + Safari) ── */
  .showcase-iphone .ios-screen {
    position: relative;
    width: 390px;
    height: 830px;
    border-radius: 49px;
    display: flex;
    flex-direction: column;
    background: #f7f7f7;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .showcase-iphone .ios-screen {
    background: #1c1c1e;
  }

  /* iOS-style notification banner that drops in from the top */
  .ios-notification {
    position: absolute;
    top: 60px;
    left: 10px;
    right: 10px;
    z-index: 6;
    display: flex;
    align-items: center;
    gap: 13px;
    padding: 17px 16px;
    border-radius: 24px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0) 40%),
      rgba(40, 40, 46, 0.45);
    backdrop-filter: blur(26px) saturate(200%);
    -webkit-backdrop-filter: blur(26px) saturate(200%);
    border: 0.5px solid rgba(255, 255, 255, 0.14);
    box-shadow: 0 14px 34px rgba(0, 0, 0, 0.28),
      0 1px 0 rgba(255, 255, 255, 0.18) inset,
      0 -1px 0 rgba(0, 0, 0, 0.12) inset;
    opacity: 0;
    transform: translateY(-160%);
    transition:
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.55s,
      opacity 0.45s ease 0.55s;
    pointer-events: none;
  }

  .ios-notif-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, #3b82f6, #1d4ed8);
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.25),
      0 1px 0 rgba(255, 255, 255, 0.35) inset;
  }

  .ios-notif-icon svg {
    width: 29px;
    height: 29px;
    overflow: visible;
  }

  .ios-notif-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    line-height: 1.35;
  }

  .ios-notif-top {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 8px;
  }

  .ios-notif-app {
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    color: #fff;
  }

  .ios-notif-time {
    flex-shrink: 0;
    font-size: 0.7rem;
    color: rgba(235, 235, 245, 0.6);
  }

  .ios-notif-title {
    font-size: 0.88rem;
    font-weight: 600;
    color: #fff;
  }

  .ios-notif-text {
    font-size: 0.84rem;
    color: rgba(235, 235, 245, 0.85);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .showcase-layout.is-visible .ios-notification {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .ios-notification {
      transition: none;
    }
  }

  /* Status bar */
  .ios-statusbar {
    position: relative;
    z-index: 3;
    flex-shrink: 0;
    height: 54px;
    padding: 0 34px 0 38px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #fff;
    background: #f7f7f7;
    color: #000;
  }

  .ios-time {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    padding-top: 6px;
  }

  .ios-status-right {
    display: flex;
    align-items: center;
    gap: 7px;
    padding-top: 6px;
  }

  .ios-signal { width: 18px; height: 12px; fill: #000; }
  .ios-wifi { width: 16px; height: 12px; fill: #000; }

  .ios-battery {
    position: relative;
    display: inline-block;
    width: 25px;
    height: 12px;
    border: 1px solid rgba(0,0,0,0.4);
    border-radius: 3px;
    padding: 1.5px;
  }

  .ios-battery::after {
    content: "";
    position: absolute;
    right: -3px;
    top: 50%;
    transform: translateY(-50%);
    width: 1.5px;
    height: 4px;
    background: rgba(0,0,0,0.4);
    border-radius: 0 1px 1px 0;
  }

  .ios-battery-level {
    display: block;
    width: 100%;
    height: 100%;
    background: #000;
    border-radius: 1px;
  }

  /* Scrolling content */
  .ios-content {
    flex: 1;
    overflow: hidden;
    background: #fff;
    position: relative;
  }

  /* ── Lakes Area Surfacing — rebuilt from the site's own markup ── */
  .las {
    font-family: "Inter", system-ui, -apple-system, sans-serif;
    background: #0b2238;
    overflow: hidden;
  }

  .las-hero {
    position: relative;
    min-height: 100%;
    display: flex;
    flex-direction: column;
