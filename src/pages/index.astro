  .pd-cta-band {
    background: #1a2332;
    color: #fff;
    padding: 28px 16px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .pd-cta-band h2 {
    font-size: 16px;
    font-weight: 900;
    margin: 0;
    line-height: 1.2;
  }

  .pd-cta-band p {
    font-size: 10px;
    color: rgba(255,255,255,0.7);
    margin: 0 0 4px;
  }

  .pd-cta-band .pd-btn-primary {
    border-color: #c8811a;
  }

  /* Force true black metal — override devices.css pink/purple tint */
  /* Light mode — silver metal rail with a black front bezel.
     border = silver rail edge, inset highlight = silver rim,
     6px inner ring + face = black bezel around the screen. */
  .showcase-iphone .device-frame {
    background: #050505;
    border-color: #c8cacb;
    box-shadow: inset 0 0 4px 2px #e2e3e4, inset 0 0 0 6px #050505;
    /* contain the screen's z-indexes so the status bar can't paint
       over the Dynamic Island, which renders as a sibling above the frame */
    isolation: isolate;
  }

  /* Dark mode — black metal */
  :global([data-theme="dark"]) .showcase-iphone .device-frame {
    background: #050505;
    border-color: #1a1a1a;
    box-shadow: inset 0 0 4px 2px #333, inset 0 0 0 6px #1c1c1e;
  }

  /* keep the Dynamic Island / sensors above the screen chrome */
  .showcase-iphone .device-header,
  .showcase-iphone .device-sensors {
    z-index: 5;
  }

  /* Side buttons — silver in light mode */
  .showcase-iphone .device-btns,
  .showcase-iphone .device-btns::before,
  .showcase-iphone .device-btns::after,
  .showcase-iphone .device-power {
    background: #b4b4b8;
  }

  /* Side buttons — dark in dark mode */
  :global([data-theme="dark"]) .showcase-iphone .device-btns,
  :global([data-theme="dark"]) .showcase-iphone .device-btns::before,
  :global([data-theme="dark"]) .showcase-iphone .device-btns::after,
  :global([data-theme="dark"]) .showcase-iphone .device-power {
    background: #1c1c1e;
  }

  .showcase-copy {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .showcase-heading {
    font-size: clamp(1.7rem, 3vw, 2.4rem);
    line-height: 1.15;
    margin: 0 0 14px;
  }

  .showcase-sub {
    font-size: 1rem;
    color: var(--ink-soft);
    line-height: 1.6;
    margin: 0 0 28px;
  }

  .showcase-callouts {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: grid;
    gap: 20px;
  }

  .showcase-callout {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .showcase-check {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--brand);
    color: #fff;
    margin-top: 2px;
  }

  .showcase-check svg {
    width: 14px;
    height: 14px;
  }

  .showcase-callout strong {
    display: block;
    font-size: 1.05rem;
    color: var(--brand);
    margin-bottom: 4px;
  }

  .showcase-callout p {
    margin: 0;
    font-size: 0.93rem;
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .showcase-cta {
    align-self: flex-start;
  }

  @media (max-width: 860px) {
    .showcase-layout {
      grid-template-columns: 1fr;
    }
    .showcase-iphone {
      transform: scale(0.52) perspective(1000px) rotateY(0deg) rotateX(1deg);
      margin: calc(868px * -0.24) calc(428px * -0.24);
    }
  }

  /* 1. Hero */
  .hero {
    background: var(--surface-soft);
    padding: calc(72px + 90px) 0 0;
    margin-top: -72px;
    border-bottom: 1px solid var(--line);
    overflow: hidden;
    position: relative;
  }

  :global([data-theme="dark"]) .hero {
    background: var(--bg);
  }

  .hero > .container {
    position: relative;
    z-index: 1;
  }

  .hero-inner {
    max-width: 820px;
    margin: 0 auto;
    position: relative;
    isolation: isolate;
  }

  .hero-tagline {
    font-size: 0.88rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--brand);
    margin: 0 0 14px;
  }

  .hero-inner h1 {
    font-size: clamp(1.6rem, 4.4vw, 3.5rem);
    white-space: nowrap;
  }


  .hero-lead {
    margin: 0 auto;
  }

  .hl {
    background: linear-gradient(120deg, var(--brand), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* Slow, deliberate entrance for each section's header block */
  @media (prefers-reduced-motion: no-preference) {
    .center-narrow[data-reveal] {
      transition-duration: 1.4s;
      transform: translateY(40px);
    }
  }

  .hero-actions {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
    margin: 28px 0 0;
  }

  .hero-trust {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-top: 32px;
    padding: 10px 20px;
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    border: 1px solid var(--line);
    border-radius: 999px;
    backdrop-filter: blur(8px);
    white-space: nowrap;
  }

  .hero-trust-rating {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .hero-trust-stars {
    color: #f59e0b;
    font-size: 0.85rem;
    letter-spacing: -0.5px;
  }

  .hero-trust-score {
    font-weight: 800;
    font-size: 0.9rem;
    color: var(--ink);
  }

  .hero-trust-label {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-soft);
    white-space: nowrap;
  }

  .hero-trust-divider {
    width: 1px;
    height: 18px;
    background: var(--line);
    flex-shrink: 0;
  }

  .hero-trust-avatars {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .avatar-stack {
    display: flex;
  }

  .avatar {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--surface-soft);
    border: 2px solid var(--surface);
    margin-left: -6px;
    flex-shrink: 0;
  }

  .avatar:first-child { margin-left: 0; }

  .hero-trust-trades {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .hero-trade-chip {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--ink-soft);
    background: var(--surface-soft);
    border: 1px solid var(--line);
    padding: 3px 10px;
    border-radius: 999px;
  }

  @media (max-width: 640px) {
    .hero-trust-divider { display: none; }
    .hero-trust { border-radius: 20px; }
  }

  /* Browser mockup */
  .hero-visual {
    margin-top: 24px;
  }

  .hero-tilt {
    transform: perspective(1800px) rotateX(18deg) scale(0.88, 0.88);
    transform-origin: 50% 50%;
    will-change: transform;
    max-width: 1340px;
    margin: 0 auto;
  }

  .hero-shot {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 16px;
    box-shadow: var(--shadow-lg);
    pointer-events: none;
  }

  /* 2. Trusted */
  .trusted {
    padding: 40px 0;
    border-bottom: 1px solid var(--line);
  }

  .trusted-label {
    color: var(--muted);
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 18px;
  }

  /* Logo marquee */
  .logo-marquee {
    position: relative;
    margin-top: 6px;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 8%,
      #000 92%,
      transparent
    );
  }

  .logo-track {
    display: flex;
    width: max-content;
    gap: 24px;
    padding: 20px 12px;
    animation: logoScroll 60s linear infinite;
  }

  .logo-marquee:hover .logo-track {
    animation-play-state: paused;
  }

  .logo-item {
    flex-shrink: 0;
    width: 168px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .logo-img {
    max-height: 52px;
    max-width: 140px;
    width: auto;
    object-fit: contain;
    opacity: 0.65;
    filter: grayscale(1);
    transition: opacity 0.25s ease, filter 0.25s ease;
  }

  .logo-item:hover .logo-img {
    opacity: 1;
    filter: grayscale(0);
  }

  :global([data-theme="dark"]) .logo-img {
    filter: grayscale(1) brightness(0) invert(1);
    opacity: 0.7;
  }

  :global([data-theme="dark"]) .logo-item:hover .logo-img {
    filter: none;
    opacity: 1;
  }

  @keyframes logoScroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-track {
      animation: none;
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  /* Featured pull-quote — light band, blue text */
  .pquote {
    position: relative;
    overflow: hidden;
    padding: clamp(64px, 9vw, 104px) 0;
    background: var(--surface-soft);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
  }

  .pquote-panel {
    position: relative;
    max-width: 980px;
    margin: 0 auto;
    padding: 0 clamp(8px, 2vw, 24px);
  }

  .pquote-glow {
    position: absolute;
    width: 460px;
    height: 460px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(37, 99, 235, 0.16), transparent 65%);
    filter: blur(60px);
    z-index: 0;
    top: -180px;
    right: -40px;
    animation: pqGlow 9s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes pqGlow {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-34px, 34px) scale(1.16); }
  }

  .pquote-inner {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .pquote-stars {
    display: flex;
    justify-content: center;
    gap: 5px;
    margin-bottom: 26px;
  }

  .pquote-star {
    color: #fbbf24;
    font-size: 1.2rem;
  }

  .pquote-text {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    line-height: 1.34;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--ink-soft);
    margin: 0;
    text-wrap: balance;
  }

  .pquote-word {
    display: inline-block;
  }

  .pquote-hl {
    color: var(--brand);
  }

  .pquote-author {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    margin-top: 38px;
  }

  .pquote-face {
    width: 54px;
    height: 54px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 800;
    font-size: 1.05rem;
    box-shadow: 0 0 0 2px rgba(37, 99, 235, 0.18);
  }

  .pquote-id {
    text-align: left;
  }

  .pquote-name {
    font-weight: 700;
    color: var(--ink);
    font-size: 1.02rem;
    line-height: 1.2;
  }

  .pquote-role {
    font-size: 0.88rem;
    color: var(--ink-soft);
    line-height: 1.3;
  }

  .pquote-src {
    width: 30px;
    height: 30px;
    margin-left: 6px;
    background: #fff;
    border-radius: 7px;
    padding: 4px;
    display: grid;
    place-items: center;
    box-shadow: var(--shadow-sm);
  }

  @media (max-width: 640px) {
    .pquote {
      padding: 56px 0;
    }
  }

  .surface-soft {
    background: var(--surface-soft);
  }

  /* FAQ */
  .faq {
    display: grid;
    gap: 12px;
  }

  .faq-item {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 4px 20px;
  }

  .faq-item summary {
    cursor: pointer;
    font-weight: 700;
    padding: 16px 0;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .faq-item summary::-webkit-details-marker {
    display: none;
  }

  .faq-item summary::after {
    content: "+";
    font-size: 1.4rem;
    color: var(--brand);
    font-weight: 400;
    flex-shrink: 0;
  }

  .faq-item[open] summary::after {
    content: "−";
  }

  .faq-item p {
    padding-bottom: 16px;
    margin: 0;
    color: var(--ink-soft);
  }


  /* 6. Features */
  .feature-list {
    display: grid;
    gap: 72px;
    margin-top: 56px;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .feature-row.reverse .feature-visual {
    order: -1;
  }

  .check-list {
    list-style: none;
    padding: 0;
    margin: 18px 0 0;
    display: grid;
    gap: 10px;
  }

  .check-list li {
    position: relative;
    padding-left: 30px;
    font-weight: 500;
    color: var(--ink);
  }

  .check-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    top: 0;
    width: 20px;
    height: 20px;
    display: grid;
    place-items: center;
    background: rgba(37, 99, 235, 0.12);
    color: var(--brand);
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 800;
  }

  .feature-visual {
    display: grid;
    place-items: center;
  }

  .visual-card {
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    background: radial-gradient(
        500px 300px at 30% 0%,
        rgba(37, 99, 235, 0.18),
        transparent
      ),
      linear-gradient(160deg, #131d33, #0b1120);
    display: grid;
    place-content: center;
    justify-items: center;
    gap: 14px;
    box-shadow: var(--shadow-lg);
  }

  .visual-icon {
    font-size: 3.5rem;
  }

  .visual-title {
    color: #fff;
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  /* Devices showcase */
  .devices-frame {
    position: relative;
    margin-top: 56px;
    border-radius: 24px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: var(--surface-soft);
    min-height: 520px;
  }

  .devices-panels {
    position: relative;
    width: 100%;
    min-height: 520px;
  }

  .devices-panel {
    position: absolute;
    inset: 0;
    display: block;
    padding: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .devices-panel.active {
    opacity: 1;
    pointer-events: auto;
    position: relative;
  }

  .devices-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  /* "Visit live site" overlay on hover */
  .devices-visit {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
    color: #fff;
    background: rgba(15, 23, 42, 0.72);
    backdrop-filter: blur(6px);
    opacity: 0;
    transform: translateY(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  .devices-panel:hover .devices-visit {
    opacity: 1;
    transform: translateY(0);
  }


  /* browser scene */
  .devices-browser-scene {
    display: flex;
    justify-content: center;
    width: 100%;
    max-width: 720px;
  }

  .devices-browser {
    width: 100%;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: var(--surface);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
  }

  .devices-browser-bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    background: var(--surface-soft);
    border-bottom: 1px solid var(--line);
  }

  .devices-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--line);
    flex-shrink: 0;
  }

  .devices-url {
    margin-left: 10px;
    font-size: 0.8rem;
    color: var(--muted);
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 4px 14px;
  }

  .devices-browser-body {
    padding: 28px 28px 36px;
  }

  .devices-dash-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 18px;
  }

  .devices-dash-title {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--ink);
  }

  .devices-dash-badge {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--brand);
    background: var(--brand-tint);
    padding: 4px 10px;
    border-radius: 999px;
  }

  .devices-dash-rows {
    display: grid;
    gap: 10px;
  }

  .devices-dash-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border: 1px solid var(--line);
    border-radius: 10px;
    font-size: 0.9rem;
    color: var(--ink);
    background: var(--surface-soft);
  }

  .devices-dash-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--brand);
    flex-shrink: 0;
  }

  /* floating toggle */
  .devices-toggle {
    position: absolute;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 4px;
    padding: 5px;
    max-width: calc(100% - 32px);
    overflow-x: auto;
    scrollbar-width: none;
    background: color-mix(in srgb, var(--ink) 88%, transparent);
    border-radius: 10px;
    backdrop-filter: blur(12px);
    box-shadow: var(--shadow-lg);
    z-index: 2;
  }

  .devices-toggle::-webkit-scrollbar {
    display: none;
  }

  .devices-btn {
    border: 0;
    background: transparent;
    font: inherit;
    font-size: 0.88rem;
    font-weight: 700;
    color: rgba(255,255,255,0.55);
    padding: 9px 22px;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.18s ease, color 0.18s ease;
    white-space: nowrap;
  }

  .devices-btn.active {
    background: #fff;
    color: #0f1218;
  }

  @media (max-width: 640px) {
    .devices-frame {
      min-height: 320px;
    }
    .devices-panels {
      min-height: 320px;
    }
    .devices-btn {
      padding: 8px 14px;
      font-size: 0.8rem;
    }
  }

  /* 7. Testimonials — review wall ticker */
  .rv-wall {
    margin-top: 56px;
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .rv-marquee {
    position: relative;
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
    mask-image: linear-gradient(
      to right,
      transparent,
      #000 6%,
      #000 94%,
      transparent
    );
  }

  .rv-track {
    display: flex;
    width: max-content;
    gap: 20px;
    padding: 4px 10px;
  }

  .rv-set {
    display: flex;
    gap: 20px;
  }

  .rv-track-a {
    animation: rvScrollA 64s linear infinite;
  }

  .rv-track-b {
    animation: rvScrollB 64s linear infinite;
  }

  .rv-marquee:hover .rv-track {
    animation-play-state: paused;
  }

  @keyframes rvScrollA {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @keyframes rvScrollB {
    from {
      transform: translateX(-50%);
    }
    to {
      transform: translateX(0);
    }
  }

  .rv {
    flex-shrink: 0;
    width: 360px;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 22px 24px;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .rv-top {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .rv-face {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--surface-soft);
  }

  .rv-mono {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    flex-shrink: 0;
    display: grid;
    place-items: center;
    color: #fff;
    font-weight: 800;
    font-size: 1.05rem;
  }

  .rv-id {
    display: flex;
    flex-direction: column;
    min-width: 0;
    flex: 1;
  }

  .rv-name {
    font-weight: 700;
    font-size: 0.98rem;
    color: var(--ink);
    line-height: 1.2;
  }

  .rv-role {
    font-size: 0.8rem;
    color: var(--muted);
    line-height: 1.3;
  }

  .rv-src {
    flex-shrink: 0;
    width: 26px;
    height: 26px;
    line-height: 0;
  }

  .rv-stars {
    color: #f5a623;
    font-size: 0.95rem;
    letter-spacing: 1px;
    line-height: 1;
  }

  .rv-quote {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--ink-soft);
  }

  @media (max-width: 640px) {
    .rv {
      width: 300px;
    }
  }


  /* 9. Blog */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-top: 48px;
  }

  .blog-card {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .blog-card.feature {
    grid-row: span 2;
    grid-column: span 1;
  }

  .blog-thumb {
    aspect-ratio: 16 / 10;
    background: linear-gradient(150deg, var(--brand), var(--accent));
    position: relative;
  }

  .blog-card.feature .blog-thumb {
    aspect-ratio: 16 / 14;
  }

  .blog-tag {
    position: absolute;
    top: 14px;
    left: 14px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--brand);
    font-weight: 700;
    font-size: 0.74rem;
    padding: 5px 12px;
    border-radius: 999px;
  }

  .blog-body {
    padding: 20px 22px 24px;
  }

  .blog-kind {
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .blog-body h3 {
    margin: 8px 0 0;
    font-size: 1.1rem;
  }

  /* 10. Community */
  .community {
    margin-top: 48px;
    gap: 24px;
  }

  .comm-card {
    display: flex;
    gap: 18px;
    align-items: flex-start;
  }

  .comm-icon {
    flex: none;
    width: 48px;
    height: 48px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    background: var(--brand-tint);
    color: var(--brand);
    font-size: 1.4rem;
  }

  .comm-card strong {
    display: block;
    font-size: 1.1rem;
    margin-bottom: 6px;
  }

  .btn-sm {
    padding: 9px 18px;
    font-size: 0.88rem;
    margin-top: 8px;
  }

  @media (max-width: 860px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
    .feature-row,
    .feature-row.reverse {
      grid-template-columns: 1fr;
    }
    .feature-row.reverse .feature-visual {
      order: 0;
    }
    .blog-card.feature {
      grid-row: auto;
    }
  }

  /* Tint card containers a light blue so they pop on white sections */
  .benefit-card,
  .blog-card {
    background: color-mix(in srgb, var(--brand) 7%, var(--surface));
  }

  /* ── Mobile ── */
  @media (max-width: 640px) {

    /* Hero */
    .hero {
      padding-top: calc(60px + 72px);
    }

    .hero-inner h1 {
      white-space: normal;
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .hero-tagline {
      font-size: 0.78rem;
    }

    .hero-lead {
      font-size: 1rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-actions .btn {
      width: 100%;
      max-width: 320px;
      justify-content: center;
    }

    .hero-trust {
      flex-wrap: wrap;
      gap: 8px;
      padding: 10px 14px;
      white-space: normal;
      text-align: center;
      justify-content: center;
    }

    /* Disable 3-D tilt on small screens — just show image flat */
    .hero-tilt {
      transform: none !important;
    }

    .hero-visual {
      margin-top: 36px;
    }

    /* Logo marquee */
    .logo-track {
      gap: 16px;
    }

    .logo-item {
      width: 128px;
      height: 52px;
    }

    .logo-img {
      max-height: 40px;
      max-width: 108px;
    }

    /* Benefit cards — already stacked by 860px rule, just tighten padding */
    .benefit-section {
