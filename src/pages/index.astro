  .pd-img-pool     { background-color: #1a4a6b; background-image: linear-gradient(135deg,#1a4a6b,#0d7cba); }
  .pd-img-concrete { background-color: #555; background-image: linear-gradient(135deg,#555,#888); }
  .pd-img-hardscape{ background-color: #3a5a3a; background-image: linear-gradient(135deg,#3a5a3a,#5a8a5a); }
  .pd-img-remodel  { background-color: #5a3a1a; background-image: linear-gradient(135deg,#5a3a1a,#8a6030); }

