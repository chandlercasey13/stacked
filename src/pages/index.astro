</style>

<script>
  // Testimonials — stacked deck of cards
  (function () {
    const stack = document.getElementById("tstack");
    if (!stack) return;
    const stackEl: HTMLElement = stack;

    const wrap = stack.closest<HTMLElement>(".tstack-wrap");
    const cards = Array.from(stack.querySelectorAll<HTMLElement>(".tcard"));
    const dots = Array.from(
      (wrap ?? stack).querySelectorAll<HTMLElement>(".tstack-dot")
    );
    const arrows = Array.from(
      (wrap ?? stack).querySelectorAll<HTMLElement>(".tstack-arrow")
    );
    const n = cards.length;
    if (!n) return;

    let active = 0;

    function sizeStack() {
      let h = 0;
      cards.forEach((c) => {
        c.style.minHeight = "";
        h = Math.max(h, c.offsetHeight);
      });
      cards.forEach((c) => (c.style.minHeight = h + "px"));
      stackEl.style.height = h + "px";
    }

    function render() {
      cards.forEach((card, i) => {
        const depth = (i - active + n) % n;
        const visible = depth <= 2;
        card.style.transform = `translateY(${depth * 16}px) scale(${1 - depth * 0.05})`;
        card.style.opacity = visible ? "1" : "0";
        card.style.zIndex = String(n - depth);
        card.style.pointerEvents = depth === 0 ? "auto" : "none";
        card.setAttribute("aria-hidden", depth === 0 ? "false" : "true");
      });
      dots.forEach((d, i) => d.classList.toggle("is-active", i === active));
    }

    function go(dir: number) {
      active = (active + dir + n) % n;
      render();
    }

    cards.forEach((card) =>
      card.addEventListener("click", () => go(1))
    );
    arrows.forEach((a) =>
      a.addEventListener("click", (e) => {
        e.stopPropagation();
        go(Number(a.getAttribute("data-dir")) || 1);
      })
    );
    dots.forEach((d, i) =>
      d.addEventListener("click", (e) => {
        e.stopPropagation();
        active = i;
        render();
      })
    );

    // Auto-advance, pause on hover
    let timer = window.setInterval(() => go(1), 6000);
    stack.addEventListener("mouseenter", () => clearInterval(timer));
    stack.addEventListener("mouseleave", () => {
      timer = window.setInterval(() => go(1), 6000);
    });

    sizeStack();
    render();
    window.addEventListener("load", sizeStack);
    window.addEventListener("resize", sizeStack);
  })();

  // Hero browser scroll tilt (lerped, runs on a continuous rAF loop)
  (function () {
    const visual = document.querySelector<HTMLElement>(".hero-visual");
    const tiltEl = visual?.querySelector<HTMLElement>(".hero-tilt");
    if (!visual || !tiltEl) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      tiltEl.style.transform = "none";
      return;
    }

    const MAX_TILT = 18;
    const MIN_SCALE = 0.88;
    const LERP = 0.12; // lower = smoother/slower chase

    const MIN_SCALE_Y = 0.88;
    let currentTilt = MAX_TILT;
    let currentScale = MIN_SCALE;
    let currentScaleY = MIN_SCALE_Y;

    function targets() {
      const range = window.innerHeight * 0.2;
      const progress = Math.min(1, Math.max(0, window.scrollY) / range);
      return {
        tilt: MAX_TILT * (1 - progress),
        scale: MIN_SCALE + (1 - MIN_SCALE) * progress,
        scaleY: MIN_SCALE_Y + (1 - MIN_SCALE_Y) * progress,
      };
    }

    function frame() {
      const { tilt, scale, scaleY } = targets();
      currentTilt += (tilt - currentTilt) * LERP;
      currentScale += (scale - currentScale) * LERP;
      currentScaleY += (scaleY - currentScaleY) * LERP;
      tiltEl.style.transform = `perspective(1800px) rotateX(${currentTilt.toFixed(3)}deg) scale(${currentScale.toFixed(4)}, ${currentScaleY.toFixed(4)})`;
      requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  })();

  // Devices toggle
  const devicesToggle = document.getElementById("devicesToggle");
  devicesToggle?.querySelectorAll<HTMLElement>(".devices-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.getAttribute("data-target")!;
      devicesToggle.querySelectorAll(".devices-btn").forEach((b) =>
        b.classList.remove("active")
      );
      btn.classList.add("active");
      document.querySelectorAll<HTMLElement>(".devices-panel").forEach((p) =>
        p.classList.toggle("active", p.getAttribute("data-panel") === target)
      );
    });
  });
</script>

<script is:inline>
  // Force autoplay on hero video — browsers sometimes ignore the attribute
  (function () {
    var v = document.querySelector(".hero-shot");
    if (v && v.tagName === "VIDEO") {
      v.play().catch(function () {});
    }
  })();
</script>
