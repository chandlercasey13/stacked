  /* Trust bar */
  .pd-trust {
    display: flex;
    background: #c8811a;
    color: #fff;
  }

  .pd-trust-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 12px 6px;
    border-right: 1px solid rgba(255,255,255,0.25);
