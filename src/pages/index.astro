// Pricing (condensed)
const plans = [
  {
    name: "Max",
    price: "$250",
    blurb: "Unlimited leads, full SEO, and review collection to scale.",
    featured: true,
    features: [
      "Unlimited leads",
      "Unlimited SEO pages",
      "Hosting, domain & SMS alerts",
      "Review collection",
      "Priority support",
    ],
  },
];

// Testimonials — two-row review wall (matches Claude Design)
const reviewWall = [
  // Row A — scrolls left
  [
    { face: "/avatars/c1.jpg", name: "Brett Simmons", role: "Owner · Big Daddy Landscaping", src: "google", stars: "★★★★★", quote: "We booked several hundred thousand dollars of work in the first few months after launching our Stacked site. Quick, responsive, and honest." },
    { mono: "GR", bg: "#0f766e", name: "Glenn Robertson", role: "Founder · Texas State Builders", src: "trustpilot", stars: "★★★★★", quote: "Took me 15 minutes to set up. A few days later I had 4–7 leads a day texted to my phone. I think I'll double revenue this month." },
    { face: "/avatars/c3.jpg", name: "Cassandra Lee", role: "Owner · Riverside Lawn & Landscape", src: "google", stars: "★★★★★", quote: "The site works perfect. Cheaper than I expected and I saw a real jump in traffic, bookings, and sales." },
