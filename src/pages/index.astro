</style>

<script>
  // Featured pull-quote — word-by-word reveal on scroll into view
  (function () {
    const sec = document.querySelector<HTMLElement>(".pquote");
    if (!sec) return;
    const words = Array.from(sec.querySelectorAll<HTMLElement>(".pquote-word"));
    const stars = Array.from(sec.querySelectorAll<HTMLElement>(".pquote-star"));
    const author = sec.querySelector<HTMLElement>(".pquote-author");
    const clamp = (x: number) => Math.max(0, Math.min(1, x));
    const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);

    const settle = () => {
      words.forEach((w) => { w.style.opacity = "1"; w.style.transform = "none"; });
      stars.forEach((s) => { s.style.opacity = "1"; s.style.transform = "none"; });
      if (author) { author.style.opacity = "1"; author.style.transform = "none"; }
    };

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      settle();
      return;
    }

    words.forEach((w) => { w.style.opacity = "0"; w.style.transform = "translateY(15px)"; });
    stars.forEach((s) => { s.style.opacity = "0"; s.style.transform = "scale(0)"; s.style.transformOrigin = "center"; });
    if (author) { author.style.opacity = "0"; author.style.transform = "translateY(18px)"; }

    let frames = 0;
    let start = 0;
    setTimeout(() => { if (frames === 0) settle(); }, 3400);

    const inView = () => {
      const r = sec.getBoundingClientRect();
      return r.top < (window.innerHeight || 800) * 0.8 && r.bottom > 0;
    };

    const tick = (now: number) => {
      frames++;
      if (!start) {
        if (inView()) start = now;
        else { requestAnimationFrame(tick); return; }
      }
      const t = now - start;
      stars.forEach((s, i) => {
        const e = easeOut(clamp((t - i * 70) / 320));
        s.style.opacity = String(e);
        s.style.transform = `scale(${(0.3 + 0.7 * e).toFixed(3)})`;
      });
      words.forEach((w, i) => {
        const e = easeOut(clamp((t - 360 - i * 42) / 470));
        w.style.opacity = String(e);
        w.style.transform = `translateY(${((1 - e) * 15).toFixed(2)}px)`;
      });
      if (author) {
        const e = easeOut(clamp((t - (360 + words.length * 42 + 160)) / 520));
        author.style.opacity = String(e);
        author.style.transform = `translateY(${((1 - e) * 18).toFixed(2)}px)`;
      }
      requestAnimationFrame(tick);
    };
    requestAnimationFrame(tick);
  })();

  // Hero browser scroll tilt (lerped, runs on a continuous rAF loop)
  (function () {
    const visual = document.querySelector<HTMLElement>(".hero-visual");
    const tiltEl = visual?.querySelector<HTMLElement>(".hero-tilt");
    if (!visual || !tiltEl) return;

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      tiltEl.style.transform = "none";
      return;
    }

    const MAX_TILT = 18;
    const MIN_SCALE = 0.88;
    const LERP = 0.12; // lower = smoother/slower chase

    const MIN_SCALE_Y = 0.88;
    let currentTilt = MAX_TILT;
    let currentScale = MIN_SCALE;
    let currentScaleY = MIN_SCALE_Y;

    function targets() {
      const range = window.innerHeight * 0.2;
      const progress = Math.min(1, Math.max(0, window.scrollY) / range);
      return {
        tilt: MAX_TILT * (1 - progress),
        scale: MIN_SCALE + (1 - MIN_SCALE) * progress,
        scaleY: MIN_SCALE_Y + (1 - MIN_SCALE_Y) * progress,
      };
    }

    function frame() {
      const { tilt, scale, scaleY } = targets();
      currentTilt += (tilt - currentTilt) * LERP;
      currentScale += (scale - currentScale) * LERP;
      currentScaleY += (scaleY - currentScaleY) * LERP;
      tiltEl.style.transform = `perspective(1800px) rotateX(${currentTilt.toFixed(3)}deg) scale(${currentScale.toFixed(4)}, ${currentScaleY.toFixed(4)})`;
      requestAnimationFrame(frame);
    }

    requestAnimationFrame(frame);
  })();

  // Devices toggle
  const devicesToggle = document.getElementById("devicesToggle");
  devicesToggle?.querySelectorAll<HTMLElement>(".devices-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const target = btn.getAttribute("data-target")!;
      devicesToggle.querySelectorAll(".devices-btn").forEach((b) =>
        b.classList.remove("active")
      );
      btn.classList.add("active");
      document.querySelectorAll<HTMLElement>(".devices-panel").forEach((p) =>
        p.classList.toggle("active", p.getAttribute("data-panel") === target)
      );
    });
  });
</script>

<script is:inline>
  // Force autoplay on hero video — browsers sometimes ignore the attribute
  (function () {
    var v = document.querySelector(".hero-shot");
    if (v && v.tagName === "VIDEO") {
      v.play().catch(function () {});
    }
  })();
</script>
