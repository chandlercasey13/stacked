    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 28px;
  }

  /* connecting line across the markers */
  .steps-row-h::before {
    content: "";
    position: absolute;
    top: 28px;
    left: 16%;
    right: 16%;
    height: 2px;
    background: linear-gradient(
      to right,
      transparent,
      var(--line) 10%,
      var(--line) 90%,
      transparent
    );
    z-index: 0;
  }

  .steps-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Staggered entrance — each step slides up, marker pops in */
  @media (prefers-reduced-motion: no-preference) {
    .steps-row-h[data-reveal-stagger] > .steps-item {
      opacity: 0;
      transform: translateY(34px);
      transition: opacity 0.6s var(--ease-out), transform 0.6s var(--ease-out);
    }
    .steps-row-h[data-reveal-stagger].is-visible > .steps-item {
      opacity: 1;
      transform: none;
    }

    .steps-row-h[data-reveal-stagger] > .steps-item .steps-marker {
      opacity: 0;
      transform: scale(0.4);
      transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
    }
    .steps-row-h[data-reveal-stagger].is-visible > .steps-item .steps-marker {
      opacity: 1;
      transform: scale(1);
    }

    .steps-row-h[data-reveal-stagger] > .steps-item:nth-child(1) {
      transition-delay: 0ms;
    }
    .steps-row-h[data-reveal-stagger] > .steps-item:nth-child(1) .steps-marker {
      transition-delay: 140ms;
    }
    .steps-row-h[data-reveal-stagger] > .steps-item:nth-child(2) {
      transition-delay: 160ms;
    }
    .steps-row-h[data-reveal-stagger] > .steps-item:nth-child(2) .steps-marker {
      transition-delay: 300ms;
    }
    .steps-row-h[data-reveal-stagger] > .steps-item:nth-child(3) {
      transition-delay: 320ms;
    }
    .steps-row-h[data-reveal-stagger] > .steps-item:nth-child(3) .steps-marker {
      transition-delay: 460ms;
    }
  }

  .steps-marker {
    position: relative;
    z-index: 1;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 1.1rem;
    font-weight: 800;
    color: #fff;
    background: var(--brand);
    border: 4px solid var(--surface-soft);
    box-shadow: 0 0 0 1px var(--line), var(--shadow-sm);
    margin-bottom: 24px;
  }

  .steps-card {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 26px 28px;
    box-shadow: var(--shadow-md);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }

  .steps-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .steps-eyebrow {
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--brand);
  }

  .steps-card h3 {
    font-size: 1.3rem;
    margin: 6px 0 8px;
    line-height: 1.2;
  }

  .steps-card p {
    margin: 0;
    color: var(--ink-soft);
    line-height: 1.6;
    font-size: 0.97rem;
  }

  .steps-stat {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
  }

  .steps-stat-value {
    font-size: 1.6rem;
    font-weight: 800;
    color: var(--brand);
    line-height: 1;
  }

  .steps-stat-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
  }

  @media (max-width: 860px) {
    .steps-row-h {
      grid-template-columns: 1fr;
      gap: 36px;
      max-width: 460px;
    }
    .steps-row-h::before {
      display: none;
    }
  }

  /* NEW: Product showcase / demo */
  .showcase-layout {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 48px;
    align-items: center;
    margin-top: 20px;
  }

  /* ── devices.css iPhone wrapper ── */
  .showcase-phone-wrap {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    padding: 48px 24px;
  }

  .iphone-glow {
    position: absolute;
    bottom: -10%;
    left: 5%;
    right: 5%;
    height: 55%;
    background: radial-gradient(ellipse at 50% 100%, color-mix(in srgb, var(--brand) 55%, transparent) 0%, transparent 70%);
    filter: blur(40px);
    z-index: 2;
    pointer-events: none;
  }

  @keyframes phoneSlideUp {
    from {
      opacity: 0;
      translate: 0 60px;
    }
    to {
      opacity: 1;
      translate: 0 0;
    }
  }

  .showcase-iphone {
    /* scale down the 868×428 native size to fit the column */
    transform: scale(0.76) perspective(1000px) rotateY(0deg) rotateX(1deg);
    transform-origin: center center;
    transition: transform 0.4s ease;
    position: relative;
    z-index: 1;
    /* preserve intrinsic size so layout isn't affected */
    margin: calc(868px * -0.12) calc(428px * -0.12);
    animation: phoneSlideUp 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .showcase-iphone:hover {
    transform: scale(0.76) perspective(1000px) rotateY(0deg) rotateX(0deg);
  }

  /* ── iOS screen chrome (status bar + Safari) ── */
  .showcase-iphone .ios-screen {
    position: relative;
    width: 390px;
    height: 830px;
    border-radius: 49px;
    display: flex;
    flex-direction: column;
    background: #f7f7f7;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .showcase-iphone .ios-screen {
    background: #1c1c1e;
  }

  /* iOS-style notification banner that drops in from the top */
  .ios-notification {
    position: absolute;
    top: 54px;
    left: -10px;
    width: calc(100% + 20px);
    max-width: none;
    height: 120px;
    object-fit: fill;
    z-index: 6;
    filter: drop-shadow(0 18px 32px rgba(0, 0, 0, 0.3))
      drop-shadow(0 0 9px rgba(56, 130, 255, 0.55));
    opacity: 0;
    transform: translateY(-160%);
    transition:
      transform 0.75s cubic-bezier(0.22, 1, 0.36, 1) 0.55s,
      opacity 0.45s ease 0.55s;
    pointer-events: none;
  }

  .showcase-layout.is-visible .ios-notification {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .ios-notification {
      transition: none;
    }
  }

  /* Status bar */
  .ios-statusbar {
    position: relative;
    z-index: 3;
    flex-shrink: 0;
    height: 54px;
    padding: 0 34px 0 38px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: #fff;
    background: #f7f7f7;
    color: #000;
  }

  .ios-time {
    font-size: 17px;
    font-weight: 600;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    padding-top: 6px;
  }

  .ios-status-right {
    display: flex;
    align-items: center;
    gap: 7px;
    padding-top: 6px;
  }

  .ios-signal { width: 18px; height: 12px; fill: #000; }
  .ios-wifi { width: 16px; height: 12px; fill: #000; }

  .ios-battery {
    position: relative;
    display: inline-block;
    width: 25px;
    height: 12px;
    border: 1px solid rgba(0,0,0,0.4);
    border-radius: 3px;
    padding: 1.5px;
  }

  .ios-battery::after {
    content: "";
    position: absolute;
    right: -3px;
    top: 50%;
    transform: translateY(-50%);
    width: 1.5px;
    height: 4px;
    background: rgba(0,0,0,0.4);
    border-radius: 0 1px 1px 0;
  }

  .ios-battery-level {
    display: block;
    width: 100%;
    height: 100%;
    background: #000;
    border-radius: 1px;
  }

  /* Scrolling content */
  .ios-content {
    flex: 1;
    overflow: hidden;
    background: #fff;
    position: relative;
  }

  /* ── Mattila Companies mobile replica (sport theme, real CSS) ── */
  .mc {
    --primary: #045bb6;
    --header-bg: #c9c9c9;
    --font-heading: "Anton", sans-serif;
    --font-body: "Outfit", system-ui, sans-serif;
    font-family: var(--font-body);
    color: #111827;
    background: #fff;
  }

  /* Header (sport, mobile) */
  .mc-header {
    height: 60px;
    background: var(--header-bg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0 1rem;
