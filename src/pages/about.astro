---
import Layout from "../layouts/Layout.astro";
import CtaBand from "../components/CtaBand.astro";
import PrismBg from "../components/PrismBg.astro";

const values = [
  {
    icon: '<path d="M3 21h18"/><path d="M5 21V10l7-5 7 5v11"/><path d="M9 21v-6h6v6"/>',
    title: "Built for contractors",
    text: "We're web designers who specialize with contractors. Every decision is made for people who'd rather be on a job site.",
  },
  {
    icon: '<rect x="5" y="2" width="14" height="20" rx="2.5"/><path d="M11 18h2"/>',
    title: "Leads over dashboards",
    text: "We text leads straight to your phone. No app to check, no dashboard to learn.",
  },
  {
    icon: '<path d="M4 4h11l5 5v11a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V5a1 1 0 0 1 1-1Z"/><path d="M14 4v5h5"/><path d="m8.5 14.5 2 2 4-4"/>',
    title: "No contracts",
    text: "Month-to-month, cancel anytime. We earn your business every single month.",
  },
  {
    icon: '<path d="M13 2 4 14h7l-1 8 9-12h-7l1-8Z"/>',
    title: "Fast to launch",
    text: "Most contractors are online within a week. Onboarding takes about five minutes.",
  },
];

---

<Layout
  title="About — Stacked"
  description="Stacked builds simple, affordable marketing systems for home-service businesses. No agency runaround, no contracts, no bull."
>
  <section class="page-hero">
    <PrismBg />
    <div class="container center-narrow text-center">
      <span class="eyebrow">About</span>
      <h1>Built for contractors,<br />by people who get it</h1>
      <p class="lead" style="margin: 0 auto;">
        Web designers who specialize with contractors. We make sites that load
        fast, rank high, and send leads straight to your phone.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="grid grid-2 about-split">
        <div>
          <span class="eyebrow">Our story</span>
          <h2>We got tired of watching good contractors lose work to bad websites</h2>
          <p>
            We're a new generation of contractors based out of Texas — a lean
            team of developers and strategists. Having worked across both
            industrial and high-tech environments, from Bell Flight to refinery
            sites, we saw firsthand how far behind most contractors are when it
            comes to technology — and how transformative even simple
            innovations can be.
          </p>
          <p>
            In an industry where ten years of experience too often means ten
            years of bad habits, we're bringing a fresh perspective. So we built
            Stacked: done-for-you websites that load fast, rank on Google, and
            text every new lead straight to your phone. Every project is
            hand-coded from scratch — no templates, no shortcuts — and we
            measure success in leads generated, rankings earned, and work
            booked. Most contractors are online within a week.
          </p>
        </div>
        <div class="about-photo-wrap">
          <img
            class="about-photo"
            src="/our-story.png"
            alt="The Stacked founders"
            width="1024"
            height="1024"
            loading="lazy"
          />
        </div>
      </div>

    </div>
  </section>

  <section class="section surface-soft">
    <div class="container">
      <div class="text-center center-narrow">
        <span class="eyebrow">What we stand for</span>
        <h2>The principles behind everything we build</h2>
      </div>
      <div class="grid grid-4 values" style="margin-top: 44px;">
        {
          values.map((v) => (
            <article class="card">
              <div class="icon-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={v.icon} />
              </div>
              <h3>{v.title}</h3>
              <p>{v.text}</p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  <CtaBand
    title="Ready to build your stack?"
    text="Start your 7-day free trial today. No contracts, cancel anytime."
  />
</Layout>

<style>
  .page-hero {
    background: var(--surface-soft);
    min-height: 360px;
    display: flex;
    align-items: center;
    padding: 72px 0;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .page-hero {
    background: var(--bg);
  }

  .page-hero > .container {
    position: relative;
    z-index: 1;
  }

  .about-split {
    align-items: center;
    gap: 56px;
  }

  .icon-badge svg {
    width: 24px;
    height: 24px;
  }

  .about-photo-wrap {
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
  }

  .about-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    aspect-ratio: 1 / 1;
  }

  .grid-4 {
    grid-template-columns: repeat(4, 1fr);
  }

  @media (max-width: 980px) {
    .grid-4 {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
