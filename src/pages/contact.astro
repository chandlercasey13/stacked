---
import Layout from "../layouts/Layout.astro";

const trades = [
  "Landscaping",
  "Roofing",
  "Plumbing",
  "HVAC",
  "Electrical",
  "Painting",
  "Remodeling",
  "Pressure Washing",
  "Pest Control",
  "Moving",
  "Flooring",
  "Other",
];
---

<Layout
  title="Contact — Stacked"
  description="Book a 20-minute demo call with Stacked. We'll answer your questions and show you live client results."
>
  <section class="page-hero">
    <div class="container center-narrow text-center">
      <span class="eyebrow">Contact</span>
      <h1>Let's get your site live</h1>
      <p class="lead" style="margin: 0 auto;">
        Tell us about your business and we'll get you set up. Or try the live
        demo below to see exactly how leads hit your phone.
      </p>
    </div>
  </section>

  <!-- SMS demo -->
  <section class="section-tight">
    <div class="container">
      <div class="sms-demo">
        <div class="sms-demo-copy">
          <span class="eyebrow">Don't believe it? Try it.</span>
          <h2>Get a demo text right now</h2>
          <p>
            Enter your phone number and we'll send you a sample lead
            notification — the same one you'd get the moment a customer reaches
            out.
          </p>
        </div>
        <form class="sms-demo-form" id="smsForm" novalidate>
          <label class="field">
            <span class="sr-only">Phone number</span>
            <input
              type="tel"
              name="demoPhone"
              required
              placeholder="(555) 123-4567"
            />
          </label>
          <button type="submit" class="btn btn-primary">Send Demo</button>
          <p class="consent">
            I agree to receive marketing messages. Message &amp; data rates may
            apply. Reply STOP to opt out.
          </p>
          <p class="sms-note" id="smsNote" hidden>✓ Demo sent! Check your phone.</p>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Prefer to reach out directly?</h2>
          <p>We're real people and we actually answer.</p>

          <ul class="info-list">
            <li>
              <span class="info-icon">✉️</span>
              <div>
                <strong>Email</strong>
                <a href="mailto:hello@getstacked.com">hello@getstacked.com</a>
              </div>
            </li>
            <li>
              <span class="info-icon">📞</span>
              <div>
                <strong>Phone</strong>
                <a href="tel:+18005550123">(800) 555-0123</a>
              </div>
            </li>
            <li>
              <span class="info-icon">🕘</span>
              <div>
                <strong>Hours</strong>
                <span>Mon–Fri, 8am–6pm</span>
              </div>
            </li>
          </ul>

          <div class="promise">
            <span class="stars">★★★★★</span>
            <p>"It took me 15 minutes to set up my site and after a few days I already saw 4–7 leads coming in daily texted to my phone." — Glenn R.</p>
          </div>
        </div>

        <form class="contact-form" id="contactForm" novalidate>
          <div class="field-row">
            <label class="field">
              <span>First name</span>
              <input type="text" name="firstName" required placeholder="Jane" />
            </label>
            <label class="field">
              <span>Last name</span>
              <input type="text" name="lastName" required placeholder="Doe" />
            </label>
          </div>

          <label class="field">
            <span>Business name</span>
            <input type="text" name="business" placeholder="Doe Plumbing Co." />
          </label>

          <div class="field-row">
            <label class="field">
              <span>Email</span>
              <input type="email" name="email" required placeholder="jane@business.com" />
            </label>
            <label class="field">
              <span>Phone</span>
              <input type="tel" name="phone" placeholder="(555) 123-4567" />
            </label>
          </div>

          <label class="field">
            <span>Your trade</span>
            <select name="trade">
              {trades.map((t) => <option value={t}>{t}</option>)}
            </select>
          </label>

          <label class="field">
            <span>What are you hoping to fix?</span>
            <textarea
              name="message"
              rows="4"
              placeholder="Tell us a bit about your business and goals…"
            ></textarea>
          </label>

          <button type="submit" class="btn btn-primary form-submit">
            Book Call
          </button>
          <p class="form-note" id="formNote" hidden>
            Thanks! This is a demo form — connect it to your CRM or email
            service to start collecting leads.
          </p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--surface-soft);
    padding: 80px 0 56px;
    border-bottom: 1px solid var(--line);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .sms-demo {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    background: var(--bg);
    color: #fff;
    border-radius: var(--radius-lg);
    padding: 40px;
    box-shadow: var(--shadow-lg);
  }

  .sms-demo-copy h2 {
    color: #fff;
  }

  .sms-demo-copy p {
    color: #cbd5e1;
    margin: 0;
  }

  .sms-demo-form {
    display: grid;
    gap: 12px;
  }

  .sms-demo-form input {
    font: inherit;
    width: 100%;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
  }

  .sms-demo-form input::placeholder {
    color: #94a3b8;
  }

  .sms-demo-form input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
  }

  .consent {
    font-size: 0.72rem;
    color: #94a3b8;
    margin: 0;
  }

  .sms-note {
    margin: 0;
    font-weight: 700;
    color: #86efac;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 56px;
    align-items: start;
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 26px 0;
    display: grid;
    gap: 20px;
  }

  .info-list li {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .info-icon {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: var(--surface-soft);
    border: 1px solid var(--line);
    font-size: 1.2rem;
  }

  .info-list strong {
    display: block;
    font-size: 0.85rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .info-list a {
    font-weight: 700;
    color: var(--ink);
  }

  .promise {
    margin-top: 30px;
    padding: 22px;
    border-radius: var(--radius);
    background: var(--surface-soft);
    border: 1px solid var(--line);
  }

  .promise p {
    margin: 8px 0 0;
    font-style: italic;
    color: var(--ink);
  }

  .contact-form {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px;
    box-shadow: var(--shadow-md);
    display: grid;
    gap: 18px;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .field {
    display: grid;
    gap: 7px;
  }

  .field span {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .field input,
  .field select,
  .field textarea {
    font: inherit;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--surface);
    color: var(--ink);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }

  .field textarea {
    resize: vertical;
  }

  .form-submit {
    width: 100%;
    margin-top: 6px;
  }

  .form-note {
    margin: 0;
    font-size: 0.9rem;
    color: var(--brand);
    font-weight: 600;
    text-align: center;
  }

  @media (max-width: 860px) {
    .contact-grid,
    .sms-demo {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .contact-grid {
      gap: 40px;
    }
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const note = document.getElementById("formNote");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    note?.removeAttribute("hidden");
    form.reset();
  });

  const smsForm = document.getElementById("smsForm") as HTMLFormElement | null;
  const smsNote = document.getElementById("smsNote");
  smsForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!smsForm.checkValidity()) {
      smsForm.reportValidity();
      return;
    }
    smsNote?.removeAttribute("hidden");
    smsForm.reset();
  });
</script>
