---
import Layout from "../layouts/Layout.astro";
import PrismBg from "../components/PrismBg.astro";

const trades = [
  "Landscaping",
  "Roofing",
  "Plumbing",
  "HVAC",
  "Electrical",
  "Painting",
  "Remodeling",
  "Pressure Washing",
  "Pest Control",
  "Moving",
  "Flooring",
  "Other",
];
---

<Layout
  title="Contact | Stacked"
  description="Book a 20-minute demo call with Stacked. We'll answer your questions and show you live client results."
>
  <section class="page-hero">
    <PrismBg />
    <div class="container center-narrow text-center">
      <span class="eyebrow">Contact</span>
      <h1>Let's get your site live</h1>
      <p class="lead" style="margin: 0 auto;">
        Tell us about your business and we'll get you set up. Or try the live
        demo below to see exactly how leads hit your phone.
      </p>
    </div>
  </section>

  <!-- SMS demo -->
  <section class="section-tight">
    <div class="container">
      <div class="sms-demo" data-reveal>
        <div class="sms-demo-copy">
          <span class="eyebrow">Don't believe it? Try it.</span>
          <h2>Get a demo text right now</h2>
          <p>
            Enter your phone number and we'll send you a sample lead
            notification — the same one you'd get the moment a customer reaches
            out.
          </p>
        </div>
        <form class="sms-demo-form" id="smsForm" novalidate>
          <label class="field">
            <span class="sr-only">Phone number</span>
            <input
              type="tel"
              name="demoPhone"
              required
              placeholder="(555) 123-4567"
            />
          </label>
          <button type="submit" class="btn btn-primary">Send Demo</button>
          <p class="consent">
            I agree to receive marketing messages. Message &amp; data rates may
            apply. Reply STOP to opt out.
          </p>
          <p class="sms-note" id="smsNote" hidden>✓ Demo sent! Check your phone.</p>
        </form>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Prefer to reach out directly?</h2>
          <p>We're real people and we actually answer.</p>

          <ul class="info-list">
            <li>
              <span class="info-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="5" width="18" height="14" rx="2.5" />
                  <path d="m3.5 7 8.5 6 8.5-6" />
                </svg>
              </span>
              <div>
                <strong>Email</strong>
                <a href="mailto:hello@getstacked.com">hello@getstacked.com</a>
              </div>
            </li>
            <li>
              <span class="info-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z" />
                </svg>
              </span>
              <div>
                <strong>Phone</strong>
                <a href="tel:+18005550123">(800) 555-0123</a>
              </div>
            </li>
            <li>
              <span class="info-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9" />
                  <path d="M12 7v5l3.5 2" />
                </svg>
              </span>
              <div>
                <strong>Hours</strong>
                <span>Mon–Fri, 8am–6pm</span>
              </div>
            </li>
          </ul>

          <div class="promise">
            <span class="stars">★★★★★</span>
            <p class="promise-quote">"We've booked several hundred thousand dollars of work in the first few months after rolling out our new websites built by Stacked. Quick, responsive, and honest."</p>
            <cite class="promise-cite">Chris K., Jordan Marine Construction</cite>
          </div>
        </div>

        <form class="contact-form" id="contactForm" novalidate>
          <div class="field-row">
            <label class="field">
              <span>First name</span>
              <input type="text" name="firstName" required placeholder="Jane" />
            </label>
            <label class="field">
              <span>Last name</span>
              <input type="text" name="lastName" required placeholder="Doe" />
            </label>
          </div>

          <label class="field">
            <span>Business name</span>
            <input type="text" name="business" placeholder="Doe Plumbing Co." />
          </label>

          <div class="field-row">
            <label class="field">
              <span>Email</span>
              <input type="email" name="email" required placeholder="jane@business.com" />
            </label>
            <label class="field">
              <span>Phone</span>
              <input type="tel" name="phone" placeholder="(555) 123-4567" />
            </label>
          </div>

          <label class="field">
            <span>Your trade</span>
            <select name="trade">
              {trades.map((t) => <option value={t}>{t}</option>)}
            </select>
          </label>

          <label class="field">
            <span>What are you hoping to fix?</span>
            <textarea
              name="message"
              rows="4"
              placeholder="Tell us a bit about your business and goals…"
            ></textarea>
          </label>

          <button type="submit" class="btn btn-primary form-submit">
            Book Call
          </button>
          <p class="form-note" id="formNote" hidden>
            Thanks! This is a demo form — connect it to your CRM or email
            service to start collecting leads.
          </p>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  .page-hero {
    background: var(--surface-soft);
    min-height: 360px;
    display: flex;
    align-items: center;
    padding: 72px 0;
    border-bottom: 1px solid var(--line);
    position: relative;
    overflow: hidden;
  }

  :global([data-theme="dark"]) .page-hero {
    background: var(--bg);
  }

  .page-hero > .container {
    position: relative;
    z-index: 1;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    border: 0;
  }

  .sms-demo {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    background: var(--bg);
    color: #fff;
    border-radius: var(--radius-lg);
    padding: 40px;
    box-shadow: var(--shadow-lg);
  }

  /* iMessage-style bubble tail (bottom-left) */
  .sms-demo::after {
    content: "";
    position: absolute;
    left: -6px;
    bottom: 16px;
    width: 26px;
    height: 26px;
    background: var(--bg);
    border-bottom-left-radius: 24px;
    -webkit-mask: radial-gradient(circle at 0 0, transparent 18px, #000 19px);
    mask: radial-gradient(circle at 0 0, transparent 18px, #000 19px);
    transform: rotate(8deg);
    z-index: -1;
  }

  /* iMessage pop-in on reveal */
  @media (prefers-reduced-motion: no-preference) {
    .sms-demo[data-reveal] {
      opacity: 0;
      transform: scale(0.4);
      transform-origin: left bottom;
      transition: opacity 0.32s ease,
        transform 0.55s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .sms-demo[data-reveal].is-visible {
      opacity: 1;
      transform: scale(1);
    }
    /* stagger the inner content so text/form fade up after the bubble lands */
    .sms-demo[data-reveal] .sms-demo-copy,
    .sms-demo[data-reveal] .sms-demo-form {
      opacity: 0;
      transform: translateY(10px);
      transition: opacity 0.4s ease 0.28s, transform 0.4s ease 0.28s;
    }
    .sms-demo[data-reveal].is-visible .sms-demo-copy,
    .sms-demo[data-reveal].is-visible .sms-demo-form {
      opacity: 1;
      transform: none;
    }
  }

  .sms-demo-copy h2 {
    color: #fff;
  }

  .sms-demo-copy p {
    color: #cbd5e1;
    margin: 0;
  }

  .sms-demo-form {
    display: grid;
    gap: 12px;
  }

  .sms-demo-form input {
    font: inherit;
    width: 100%;
    padding: 14px 16px;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.06);
    color: #fff;
  }

  .sms-demo-form input::placeholder {
    color: #94a3b8;
  }

  .sms-demo-form input:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.3);
  }

  .consent {
    font-size: 0.72rem;
    color: #94a3b8;
    margin: 0;
  }

  .sms-note {
    margin: 0;
    font-weight: 700;
    color: #86efac;
  }

  /* Dark theme: make the demo bubble a warm cream instead of dark navy */
  :global([data-theme="dark"]) .sms-demo {
    background: #f6f1e6;
    color: #1b2430;
  }

  :global([data-theme="dark"]) .sms-demo::after {
    background: #f6f1e6;
  }

  :global([data-theme="dark"]) .sms-demo-copy h2 {
    color: #1b2430;
  }

  :global([data-theme="dark"]) .sms-demo-copy p {
    color: #51606f;
  }

  :global([data-theme="dark"]) .sms-demo-form input {
    border-color: rgba(27, 36, 48, 0.16);
    background: rgba(27, 36, 48, 0.04);
    color: #1b2430;
  }

  :global([data-theme="dark"]) .sms-demo-form input::placeholder {
    color: #8a93a0;
  }

  :global([data-theme="dark"]) .consent {
    color: #6b7686;
  }

  :global([data-theme="dark"]) .sms-note {
    color: #15803d;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 56px;
    align-items: start;
  }

  .info-list {
    list-style: none;
    padding: 0;
    margin: 26px 0;
    display: grid;
    gap: 20px;
  }

  .info-list li {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .info-icon {
    width: 44px;
    height: 44px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: var(--brand-tint);
    border: 1px solid var(--line);
    color: var(--brand);
    flex-shrink: 0;
  }

  .info-icon svg {
    width: 21px;
    height: 21px;
  }

  .info-list strong {
    display: block;
    font-size: 0.85rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .info-list a {
    font-weight: 700;
    color: var(--ink);
  }

  .promise {
    margin-top: 30px;
    padding: 22px;
    border-radius: var(--radius);
    background: var(--surface-soft);
    border: 1px solid var(--line);
  }

  .promise-quote {
    margin: 8px 0 0;
    font-style: italic;
    color: var(--ink);
    line-height: 1.55;
  }

  .promise-cite {
    display: block;
    margin-top: 12px;
    font-style: normal;
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--ink-soft);
  }

  .contact-form {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: 32px;
    box-shadow: var(--shadow-md);
    display: grid;
    gap: 18px;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  .field {
    display: grid;
    gap: 7px;
  }

  .field span {
    font-weight: 600;
    font-size: 0.9rem;
  }

  .field input,
  .field select,
  .field textarea {
    font: inherit;
    padding: 12px 14px;
    border: 1px solid var(--line);
    border-radius: 12px;
    background: var(--surface);
    color: var(--ink);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--brand);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.15);
  }

  .field textarea {
    resize: vertical;
  }

  .form-submit {
    width: 100%;
    margin-top: 6px;
  }

  .form-note {
    margin: 0;
    font-size: 0.9rem;
    color: var(--brand);
    font-weight: 600;
    text-align: center;
  }

  @media (max-width: 860px) {
    .contact-grid,
    .sms-demo {
      grid-template-columns: 1fr;
      gap: 28px;
    }
    .contact-grid {
      gap: 40px;
    }
    .field-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const form = document.getElementById("contactForm") as HTMLFormElement | null;
  const note = document.getElementById("formNote");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    note?.removeAttribute("hidden");
    form.reset();
  });

  const smsForm = document.getElementById("smsForm") as HTMLFormElement | null;
  const smsNote = document.getElementById("smsNote");
  smsForm?.addEventListener("submit", (e) => {
    e.preventDefault();
    if (!smsForm.checkValidity()) {
      smsForm.reportValidity();
      return;
    }
    smsNote?.removeAttribute("hidden");
    smsForm.reset();
  });
</script>
