---
const year = new Date().getFullYear();
const cols = [
  {
    title: "Product",
    links: [
      { href: "/#features", label: "Features" },
      { href: "/pricing", label: "Pricing" },
      { href: "/testimonials", label: "Testimonials" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/about", label: "About" },
      { href: "/contact", label: "Contact" },
    ],
  },
];
---

<footer class="site-footer dark">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-mark">▚</span>
        <span class="brand-name">Stacked</span>
      </a>
      <p>Done-for-you websites for contractors. Load fast, rank high, get paid.</p>
      <a href="/pricing" class="btn btn-primary btn-sm">Start Free Trial</a>
    </div>

    {
      cols.map((col) => (
        <div class="footer-col">
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="container footer-bottom">
    <span>© {year} Stacked. All rights reserved.</span>
    <span>
      Powered by
      <a href="https://swecontracting.com" rel="noopener">SWE Contracting</a>
      — built by web designers who specialize with contractors.
    </span>
  </div>
</footer>

<style>
  .site-footer {
    padding: 64px 0 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1.25rem;
    color: #fff;
    margin-bottom: 14px;
  }

  .brand-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    color: #fff;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand p {
    max-width: 34ch;
    margin-bottom: 18px;
  }

  .btn-sm {
    padding: 10px 20px;
    font-size: 0.9rem;
  }

  .footer-col h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin-bottom: 14px;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .footer-col a {
    color: #aab6cd;
    font-size: 0.95rem;
  }

  .footer-col a:hover {
    color: #fff;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 24px;
    color: #7e8aa3;
    font-size: 0.88rem;
  }

  .footer-bottom a {
    color: #cbd5e1;
    font-weight: 600;
  }

  .footer-bottom a:hover {
    color: #fff;
  }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
