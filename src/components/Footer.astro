---
const year = new Date().getFullYear();
const cols = [
  {
    title: "Product",
    links: [
      { href: "/#features", label: "Features" },
      { href: "/pricing", label: "Pricing" },
      { href: "/testimonials", label: "Testimonials" },
    ],
  },
  {
    title: "Company",
    links: [
      { href: "/about", label: "About" },
      { href: "/contact", label: "Contact" },
    ],
  },
];
---

<footer class="site-footer dark">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="brand">
        <span class="brand-name">Stacked</span>
        <svg class="brand-icon" viewBox="165 115 430 350" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <g fill="currentColor" stroke="var(--bg)" stroke-width="18" stroke-linejoin="round">
            <path d="M275 124.5H579C592.531 124.5 603.5 135.469 603.5 149V373C603.5 386.531 592.531 397.5 579 397.5H275C261.469 397.5 250.5 386.531 250.5 373V149C250.5 135.469 261.469 124.5 275 124.5Z"/>
            <path d="M235 164.5H539C552.531 164.5 563.5 175.469 563.5 189V413C563.5 426.531 552.531 437.5 539 437.5H235C221.469 437.5 210.5 426.531 210.5 413V189C210.5 175.469 221.469 164.5 235 164.5Z"/>
            <path d="M195 204.5H499C512.531 204.5 523.5 215.469 523.5 229V453C523.5 466.531 512.531 477.5 499 477.5H195C181.469 477.5 170.5 466.531 170.5 453V229C170.5 215.469 181.469 204.5 195 204.5Z"/>
          </g>
        </svg>
      </a>
      <p>Done-for-you websites for contractors. Load fast, rank high, get paid.</p>
      <a href="/contact" class="btn btn-primary btn-sm">Book Call</a>
    </div>

    {
      cols.map((col) => (
        <div class="footer-col">
          <h4>{col.title}</h4>
          <ul>
            {col.links.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>

  <div class="container footer-bottom">
    <span>© {year} Stacked. All rights reserved.</span>
    <span>
      Powered by
      <a href="https://swecontracting.com" rel="noopener">SWE Contracting</a>
      — built by web designers who specialize with contractors.
    </span>
  </div>
</footer>

<style>
  .site-footer {
    padding: 64px 0 32px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.25rem;
    color: #fff;
    margin-bottom: 14px;
  }

  .brand-name {
    font-weight: 400;
    line-height: 1;
    align-self: center;
    text-transform: uppercase;
  }

  .brand-icon {
    width: 28px;
    height: 22px;
    flex-shrink: 0;
    color: var(--brand);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 40px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand p {
    max-width: 34ch;
    margin-bottom: 18px;
  }

  .btn-sm {
    padding: 10px 20px;
    font-size: 0.9rem;
  }

  .footer-col h4 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    margin-bottom: 14px;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 10px;
  }

  .footer-col a {
    color: #aab6cd;
    font-size: 0.95rem;
  }

  .footer-col a:hover {
    color: #fff;
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
    padding-top: 24px;
    color: #7e8aa3;
    font-size: 0.88rem;
  }

  .footer-bottom a {
    color: #cbd5e1;
    font-weight: 600;
  }

  .footer-bottom a:hover {
    color: #fff;
  }

  @media (max-width: 860px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }
  }
</style>
