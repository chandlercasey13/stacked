---
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Ready to get your site live?",
  text = "Most contractors are online within a week of signing up. No contracts, cancel anytime.",
} = Astro.props;
---

<section class="section dark cta-band">
  <div class="container text-center center-narrow">
    <h2>{title}</h2>
    <p class="lead" style="margin: 0 auto 28px;">{text}</p>
    <div class="cta-actions">
      <a href="/pricing" class="btn btn-primary">Start 7-Day Free Trial</a>
      <a href="/contact" class="btn btn-ghost">Talk to Us</a>
    </div>
  </div>
</section>

<style>
  .cta-band {
    background: radial-gradient(
        1200px 400px at 50% -10%,
        rgba(37, 99, 235, 0.25),
        transparent
      ),
      var(--bg);
  }
  .cta-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
