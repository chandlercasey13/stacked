---
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Ready to build your stack?",
  text = "Most contractors are online within a week of signing up. Book a call and we'll have you live within a week.",
} = Astro.props;
---

<section class="section cta-section">
  <div class="container">
    <div class="cta-panel">
      <!-- floating mockups -->
      <div class="cta-float cta-float-left" aria-hidden="true">
        <div class="cta-mini-stats">
          <div class="cta-mini-stat">
            <span class="cta-mini-label">Quotes Sent</span>
            <span class="cta-mini-val">28</span>
          </div>
          <div class="cta-mini-stat">
            <span class="cta-mini-label">Jobs Won</span>
            <span class="cta-mini-val">12</span>
          </div>
        </div>
        <svg class="cta-spark" viewBox="0 0 220 70" fill="none" preserveAspectRatio="none">
          <path
            d="M2 56 L40 48 L72 52 L104 34 L140 40 L176 18 L218 8"
            stroke="#4a7fd4"
            stroke-width="3"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
          <circle cx="218" cy="8" r="5" fill="#4a7fd4"></circle>
        </svg>
        <span class="cta-mini-foot">Lead activity · this month</span>
      </div>

      <div class="cta-float cta-float-right" aria-hidden="true">
        <span class="cta-mini-head">This week</span>
        <div class="cta-mini-item">
          <span class="cta-mini-dot"></span>
          <span class="cta-mini-text">New lead — Maria R.</span>
          <span class="cta-mini-amt">+$2,400</span>
        </div>
        <div class="cta-mini-item">
          <span class="cta-mini-dot"></span>
          <span class="cta-mini-text">Payment received</span>
          <span class="cta-mini-amt">+$1,200</span>
        </div>
        <div class="cta-mini-item">
          <span class="cta-mini-dot"></span>
          <span class="cta-mini-text">Job booked — Thu 9 AM</span>
          <span class="cta-mini-amt">✓</span>
        </div>
      </div>

      <div class="cta-content">
        <h2>{title}</h2>
        <p>{text}</p>
        <div class="cta-actions">
          <a href="/contact" class="cta-btn cta-btn-light">Book Call</a>
          <a href="/contact" class="cta-btn cta-btn-outline">Talk to Us</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-section {
    padding-block: clamp(48px, 8vw, 96px);
  }

  .cta-panel {
    position: relative;
    overflow: hidden;
    border-radius: 32px;
    padding: clamp(56px, 9vw, 120px) 24px;
    text-align: center;
    background:
      radial-gradient(
        700px 320px at 50% -8%,
        rgba(255, 255, 255, 0.18),
        transparent 70%
      ),
      linear-gradient(150deg, #1e3a6e, #162d58 55%, #0f1e3d);
    box-shadow: var(--shadow-lg);
    isolation: isolate;
  }

  .cta-content {
    position: relative;
    z-index: 2;
    max-width: 760px;
    margin: 0 auto;
  }

  .cta-panel h2 {
    color: #fff;
    font-size: clamp(2rem, 5vw, 3.4rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
  }

  .cta-panel p {
    color: rgba(255, 255, 255, 0.82);
    font-size: clamp(1rem, 1.6vw, 1.15rem);
    line-height: 1.55;
    max-width: 540px;
    margin: 0 auto 32px;
  }

  .cta-actions {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 14px 28px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 0.98rem;
    text-decoration: none;
    transition: transform 0.15s ease, box-shadow 0.15s ease, background 0.15s ease;
  }

  .cta-btn-light {
    background: #fff;
    color: #0f1e3d;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.18);
  }

  .cta-btn-light:hover {
    transform: translateY(-2px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.24);
  }

  .cta-btn-outline {
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.55);
  }

  .cta-btn-outline:hover {
    background: rgba(255, 255, 255, 0.22);
    transform: translateY(-2px);
  }

  /* floating mockup cards */
  .cta-float {
    position: absolute;
    z-index: 1;
    bottom: clamp(24px, 6%, 64px);
    width: 240px;
    padding: 18px 20px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: 0 24px 50px rgba(15, 35, 80, 0.32);
    backdrop-filter: blur(4px);
  }

  .cta-float-left {
    left: clamp(-90px, 2%, 40px);
    transform: rotate(-8deg);
  }

  .cta-float-right {
    right: clamp(-90px, 2%, 40px);
    transform: rotate(7deg);
  }

  .cta-mini-stats {
    display: flex;
    gap: 22px;
    margin-bottom: 6px;
  }

  .cta-mini-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }

  .cta-mini-label {
    font-size: 0.68rem;
    font-weight: 600;
    color: #6b7280;
  }

  .cta-mini-val {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1f2937;
  }

  .cta-spark {
    width: 100%;
    height: 56px;
    display: block;
  }

  .cta-mini-foot {
    display: block;
    text-align: left;
    font-size: 0.62rem;
    font-weight: 600;
    color: #9ca3af;
  }

  .cta-mini-head {
    display: block;
    text-align: left;
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #6b7280;
    margin-bottom: 12px;
  }

  .cta-mini-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 0;
    border-top: 1px solid #eef1f6;
  }

  .cta-mini-item:first-of-type {
    border-top: 0;
  }

  .cta-mini-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #4a7fd4;
    flex-shrink: 0;
  }

  .cta-mini-text {
    font-size: 0.74rem;
    font-weight: 600;
    color: #374151;
    text-align: left;
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .cta-mini-amt {
    font-size: 0.74rem;
    font-weight: 800;
    color: #16a34a;
    flex-shrink: 0;
  }

  @media (max-width: 980px) {
    .cta-float {
      display: none;
    }
  }
</style>
