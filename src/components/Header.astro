---
const { pathname } = Astro.url;
const links = [
  { href: "/about", label: "About" },
  { href: "/pricing", label: "Pricing" },
  { href: "/testimonials", label: "Testimonials" },
  { href: "/contact", label: "Contact" },
];
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label="Stacked home">
      <span class="brand-name">Stacked</span>
      <svg class="brand-icon" viewBox="165 115 430 350" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <g fill="currentColor" stroke="var(--surface)" stroke-width="18" stroke-linejoin="round">
          <path d="M275 124.5H579C592.531 124.5 603.5 135.469 603.5 149V373C603.5 386.531 592.531 397.5 579 397.5H275C261.469 397.5 250.5 386.531 250.5 373V149C250.5 135.469 261.469 124.5 275 124.5Z"/>
          <path d="M235 164.5H539C552.531 164.5 563.5 175.469 563.5 189V413C563.5 426.531 552.531 437.5 539 437.5H235C221.469 437.5 210.5 426.531 210.5 413V189C210.5 175.469 221.469 164.5 235 164.5Z"/>
          <path d="M195 204.5H499C512.531 204.5 523.5 215.469 523.5 229V453C523.5 466.531 512.531 477.5 499 477.5H195C181.469 477.5 170.5 466.531 170.5 453V229C170.5 215.469 181.469 204.5 195 204.5Z"/>
        </g>
      </svg>
    </a>

    <nav class="nav" aria-label="Primary">
      {
        links.map((l) => (
          <a href={l.href} class:list={["nav-link", { active: isActive(l.href) }]}>
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="header-cta">
      <a href="/contact" class="btn btn-primary btn-sm">Book Call</a>
    </div>

    <button class="nav-toggle" aria-label="Toggle menu" id="navToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu">
    {links.map((l) => <a href={l.href} class="mobile-link">{l.label}</a>)}
    <a href="/contact" class="btn btn-primary">Book Call</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--surface) 85%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
    transition: background 0.3s ease, border-color 0.3s ease, backdrop-filter 0.3s ease;
  }

  .site-header.nav-transparent {
    background: transparent;
    backdrop-filter: none;
    border-bottom-color: transparent;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 72px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-weight: 800;
    font-size: 1.8rem;
    letter-spacing: -0.03em;
  }

  .brand-icon {
    display: block;
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    color: var(--brand);
    overflow: visible;
    align-self: center;
    transform: translateY(-2px) rotate(360deg);
  }

  .brand-name {
    line-height: 1;
    align-self: center;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.025em;
  }

  .nav {
    display: flex;
    gap: 6px;
  }

  .nav-link {
    padding: 8px 14px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink-soft);
    transition: color 0.15s ease, background 0.15s ease;
  }

  .nav-link:hover {
    color: var(--ink);
    background: var(--surface-soft);
  }

  .nav-link.active {
    color: var(--brand);
    background: var(--brand-tint);
  }

  .header-cta {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .btn-sm {
    padding: 10px 20px;
    font-size: 0.9rem;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 8px;
  }

  .nav-toggle span {
    width: 24px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    gap: 8px;
    padding: 16px 24px 24px;
    border-bottom: 1px solid var(--line);
    background: var(--surface);
  }

  .mobile-menu.open {
    display: flex;
  }

  .mobile-link {
    padding: 10px 4px;
    font-weight: 600;
    border-bottom: 1px solid var(--line);
  }

  @media (max-width: 860px) {
    .nav {
      display: none;
    }
    /* Hide the Book Call button (available in the mobile menu) */
    .header-cta .btn {
      display: none;
    }
    .nav-toggle {
      display: flex;
    }
  }
</style>

<script is:inline>
  (function () {
    // Light is the default. Only honor an explicitly saved "dark" preference.
    // (Dark-mode state plumbing is kept so it can still be enabled via
    //  localStorage.setItem("theme", "dark") or setting data-theme directly.)
    const saved = localStorage.getItem("theme");
    if (saved === "dark") {
      document.documentElement.setAttribute("data-theme", "dark");
    }

    // Apply transparent nav on home page before first paint
    if (window.location.pathname === "/") {
      document.querySelector(".site-header")?.classList.add("nav-transparent");
    }
  })();
</script>

<script>
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("mobileMenu");
  toggle?.addEventListener("click", () => menu?.classList.toggle("open"));

  // Transparent nav on home page hero
  const header = document.querySelector<HTMLElement>(".site-header");
  if (header && window.location.pathname === "/") {
    const applyTransparency = () => {
      if (window.scrollY < 10) {
        header.classList.add("nav-transparent");
      } else {
        header.classList.remove("nav-transparent");
      }
    };
    applyTransparency();
    window.addEventListener("scroll", applyTransparency, { passive: true });
  }
</script>
