---
// Reusable prism/liquid animated hero background.
// Drop inside any positioned hero section. The parent should have
// `position: relative; overflow: hidden;` and its content should sit
// above the canvas (e.g. `position: relative; z-index: 1;`).
---

<canvas id="liquid-bg" aria-hidden="true"></canvas>

<style>
  #liquid-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.45;
    pointer-events: none;
  }
</style>

<script>
  import { initLiquidBg } from "../scripts/liquid-bg";
  initLiquidBg();
</script>
